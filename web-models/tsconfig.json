{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "~/services/*": [
        "./src/services/*"
      ],
      "~/pages/*": [
        "./src/pages/*"
      ],
      "~/data/*": [
        "./src/data/*"
      ],
      "~/components/*": [
        "./src/components/*"
      ],
    }
  }
}