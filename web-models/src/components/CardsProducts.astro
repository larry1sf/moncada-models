---
import { Image } from "astro:assets";
import { formatPriceCOP, STRAPI_HOST } from "~/services/consts";
import type { ProductImage } from "~/types/product";

interface Props {
    slug: string;
    title: string;
    description: string;
    price: number | string;
    images: ProductImage[];
}
const { images, slug, title, description, price } = Astro.props;
// crear la funcionalidad de los slides si es un array de urls.
let image = images.length
    ? images[0].url
    : "https://images.unsplash.com/photo-1594633313593-bab3825d0caf?w=400&h=500&fit=crop";
---

<a href={`/product/${slug}`} class="product-card">
    <div class="product-image">
        <div class="product-badge">Nuevo</div>
        <Image
            width={300}
            height={300}
            transition:name={slug}
            src={image}
            alt="Chaqueta Premium"
        />
    </div>
    <div class="product-info">
        <div>
            <h3>{title ?? "Chaqueta Premium"}</h3>
            <p class="product-description">
                {description ?? "Elegancia y calidez"}
            </p>
        </div>
        <div class="product-footer">
            <span class="product-price">${formatPriceCOP(price)}{" "} Cop</span>
            <button class="add-to-cart">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path
                        d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
                    ></path>
                </svg>
            </button>
        </div>
    </div>
</a>

<style>
    .product-card {
        height: 100%;
        background: var(--color-card-bg);
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--color-border);
        transition: var(--transition);
        position: relative;
        box-shadow: var(--shadow-md);
        text-decoration: none;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-12px);
        border-color: var(--color-accent);
        box-shadow: var(--shadow-lg);
        background: var(--color-card-bg-hover);
    }

    .product-image {
        position: relative;
        width: 100%;
        height: 320px;
        overflow: hidden;
        background: var(--color-bg-dark);
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-image img {
        transform: scale(1.08);
    }

    .product-image::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(0, 0, 0, 0.1) 100%
        );
        pointer-events: none;
    }

    .product-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: linear-gradient(
            135deg,
            var(--color-accent) 0%,
            var(--color-accent-hover) 100%
        );
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        z-index: 2;
        box-shadow: var(--shadow-md);
    }

    .product-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .product-info h3 {
        margin: 0;
        color: var(--color-text-dark);
        font-family: "Playfair Display", serif;
        font-weight: 700;
        font-size: 1.3rem;
        letter-spacing: 0.02em;
    }

    .product-description {
        margin: 0;
        color: var(--color-text-medium);
        font-size: 0.9rem;
        line-height: 1.5;
        font-family: "Poppins", sans-serif;
        font-weight: 300;
    }

    .product-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
    }

    .product-price {
        color: var(--color-accent);
        font-size: 1.5rem;
        font-weight: 700;
        font-family: "Playfair Display", serif;
    }
    .add-to-cart {
        background: linear-gradient(
            135deg,
            var(--color-accent) 0%,
            var(--color-accent-hover) 100%
        );
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        color: white;
        box-shadow: var(--shadow-sm);
    }

    .add-to-cart:hover {
        transform: scale(1.1) rotate(12deg);
        box-shadow: var(--shadow-md);
        background: linear-gradient(
            135deg,
            var(--color-accent-hover) 0%,
            var(--color-accent) 100%
        );
    }

    .add-to-cart:active {
        transform: scale(0.95);
    }

    .categories-section {
        max-width: 1200px;
        margin: 0 auto 5rem auto;
        padding: 0 2rem;
        animation: fadeInUp 0.6s ease-out 0.2s both;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
