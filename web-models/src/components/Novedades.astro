---
import CardsProducts from "~/components/CardsProducts.astro";
import { products } from "~/data/products";

const novedades = products.reverse().slice(0, 6);
---

<section id="novedades" class="novedades-section">
    <div class="section-header">
        <h2>Novedades</h2>
        <p>Descubre las últimas tendencias en moda</p>
    </div>
    <div class="novedades-grid">
        {
            novedades.length &&
                novedades.map(({ name, slug, description, price, images }) => (
                    <CardsProducts
                        slug={slug}
                        title={name}
                        description={description}
                        price={price}
                        images={images}
                    />
                ))
        }
    </div>
</section>
