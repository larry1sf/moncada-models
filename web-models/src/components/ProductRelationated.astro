---
import type { ProductAttributes } from "~/types/product";
import ProductCard from "~/components/CardsProducts.astro";
import { getProductsCategories } from "~/services/get-productsCategories";
interface Props {
    product: ProductAttributes;
}

const { product } = Astro.props;

const productCategory = product.product_category.slug;
let { data: relatedProducts } = await getProductsCategories({
    productCategory,
});
relatedProducts = relatedProducts.filter(({ slug }) => slug !== product.slug);
---

<section class="product-container">
    <h3>Productos Relacionados</h3>
    <p>
        Algunos de los productos que pueden estar relacionados con {
            product.name
        }.
    </p>
    <div class="product-grid" id="related-products-grid">
        {
            relatedProducts?.map(
                ({ name, description, slug, price, images }) => (
                    <div class="product-item">
                        <ProductCard
                            title={name}
                            description={description}
                            slug={slug}
                            price={price}
                            images={images}
                        />
                    </div>
                ),
            )
        }
    </div>

    <div class="pagination-controls" id="pagination-controls">
        <button id="prev-btn" class="pagination-btn" aria-label="Anterior">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M15 18l-6-6 6-6"></path>
            </svg>
        </button>
        <div class="pagination-dots" id="pagination-dots"></div>
        <button id="next-btn" class="pagination-btn" aria-label="Siguiente">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M9 18l6-6-6-6"></path>
            </svg>
        </button>
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const grid = document.getElementById("related-products-grid");
        const items = grid?.querySelectorAll(".product-item");
        const prevBtn = document.getElementById(
            "prev-btn",
        ) as HTMLButtonElement;
        const nextBtn = document.getElementById(
            "next-btn",
        ) as HTMLButtonElement;
        const dotsContainer = document.getElementById("pagination-dots");

        if (!grid || !items || items.length === 0 || !prevBtn || !nextBtn)
            return;

        let currentPage = 0;
        let itemsPerPage = 3;
        let totalPages = 0;

        function updateItemsPerPage() {
            const width = window.innerWidth;
            if (width < 640) {
                itemsPerPage = 1;
            } else if (width < 1024) {
                itemsPerPage = 2;
            } else {
                itemsPerPage = 3;
            }
            totalPages = Math.ceil((items?.length || 0) / itemsPerPage);

            // Reset to page 0 if current page is out of bounds
            if (currentPage >= totalPages) {
                currentPage = 0;
            }

            updateDisplay();
        }

        function updateDisplay() {
            // Show/Hide items
            items?.forEach((item, index) => {
                const start = currentPage * itemsPerPage;
                const end = start + itemsPerPage;

                if (index >= start && index < end) {
                    (item as HTMLElement).style.display = "block";
                    // Add a small animation effect
                    (item as HTMLElement).style.animation =
                        "fadeIn 0.5s ease forwards";
                } else {
                    (item as HTMLElement).style.display = "none";
                }
            });

            // Update buttons
            prevBtn.disabled = currentPage === 0;
            nextBtn.disabled = currentPage >= totalPages - 1;

            // Update dots
            if (dotsContainer) {
                dotsContainer.innerHTML = "";
                // Only show dots if there's more than one page
                if (totalPages > 1) {
                    for (let i = 0; i < totalPages; i++) {
                        const dot = document.createElement("span");
                        dot.className = `pagination-dot ${i === currentPage ? "active" : ""}`;
                        dot.addEventListener("click", () => {
                            currentPage = i;
                            updateDisplay();
                        });
                        dotsContainer.appendChild(dot);
                    }
                }
            }

            // Hide controls if only one page
            const controls = document.getElementById("pagination-controls");
            if (controls) {
                controls.style.display = totalPages <= 1 ? "none" : "flex";
            }
        }

        // Event Listeners
        prevBtn.addEventListener("click", () => {
            if (currentPage > 0) {
                currentPage--;
                updateDisplay();
            }
        });

        nextBtn.addEventListener("click", () => {
            if (currentPage < totalPages - 1) {
                currentPage++;
                updateDisplay();
            }
        });

        window.addEventListener("resize", () => {
            updateItemsPerPage();
        });

        // Initialize
        updateItemsPerPage();
    });
</script>

<style>
    .product-container h3 {
        font-size: 2rem;
        color: #5a4a42;
        margin-bottom: 1rem;
        line-height: 1.3;
    }
    .product-container p {
        margin-bottom: 2rem;
        font-size: 1.4rem;
        color: var(--color-text-dark);
    }
    .product-container .product-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* Default desktop */
        gap: 2rem;
        margin-bottom: 2rem;
        color: var(--color-text-medium);
        font-size: 1.2em;
    }
    .product-item {
        height: 100%;
    }
    .product-item a {
        height: 100%;
    }

    /* Responsive Grid Overrides handled by JS display toggling, 
       but we need to ensure the grid layout respects the visible items */
    @media (max-width: 1024px) {
        .product-container .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .product-container .product-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Pagination Styles */
    .pagination-controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 2px solid var(--color-border);
        background: white;
        color: var(--color-text-dark);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .pagination-btn:hover:not(:disabled) {
        border-color: var(--color-accent);
        background: var(--color-accent);
        color: white;
        transform: translateY(-2px);
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        border-color: #eee;
        color: #ccc;
    }

    .pagination-dots {
        display: flex;
        gap: 0.5rem;
    }

    :global(.pagination-dot) {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--color-border);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    :global(.pagination-dot.active) {
        background-color: var(--color-accent);
        transform: scale(1.2);
    }

    :global(.pagination-dot:hover:not(.active)) {
        background-color: var(--color-accent-hover);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<style>
    .product-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }
    @media (max-width: 1135px) {
        .product-container {
            padding: 1rem;
        }
    }
</style>
