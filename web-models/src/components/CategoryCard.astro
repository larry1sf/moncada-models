---
import { STRAPI_HOST } from "~/services/consts";
import type { Category } from "~/data/categories";
import Image from "astro/components/Image.astro";

type Props = Category;

const { id, slug, title, description, image, productCount } = Astro.props;
---

<a href={`/category/${slug}`} class="category-card">
  <div class="card-image">
    <Image
      width={300}
      height={300}
      transition:name={slug}
      src={`${STRAPI_HOST}${image.url}`}
      alt={title}
      loading="lazy"
    />
    <div class="card-overlay"></div>
  </div>

  <div class="card-content">
    <div class="card-header">
      <span class="category-icon">{"icon"}</span>
      <h3>{title}</h3>
    </div>

    <p class="category-description">{description}</p>

    <div class="card-footer">
      <span class="product-count">
        {productCount}
        {productCount === 1 ? "producto" : "productos"}
      </span>
      <span class="arrow">→</span>
    </div>
  </div>
</a>

<!-- <style define:vars={{ color }}> -->
<style>
  .category-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: white;
    border-radius: 1.2rem;
    overflow: hidden;
    border: 2px solid rgba(232, 213, 196, 0.3);
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 4px 12px rgba(172, 140, 124, 0.08);
  }

  .category-card:hover {
    transform: translateY(-8px);
    border-color: #e8d5c4;
    box-shadow: 0 12px 24px rgba(172, 140, 124, 0.15);
  }

  .card-image {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .category-card:hover .card-image img {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* background: var(--color); */
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .category-card:hover .card-overlay {
    opacity: 0.15;
  }

  .card-content {
    flex: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
  }

  .category-icon {
    font-size: 1.8rem;
    display: block;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.4rem;
    color: #5a4a42;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .category-description {
    margin: 0 0 1rem 0;
    color: #8a7a72;
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(232, 213, 196, 0.4);
  }

  .product-count {
    font-size: 0.85rem;
    color: #a89080;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .arrow {
    font-size: 1.2rem;
    color: #c4a47a;
    transition: transform 0.3s ease;
  }

  .category-card:hover .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .card-image {
      height: 160px;
    }

    .card-content {
      padding: 1.2rem;
    }

    .card-header h3 {
      font-size: 1.2rem;
    }

    .category-description {
      font-size: 0.9rem;
    }
  }
</style>
