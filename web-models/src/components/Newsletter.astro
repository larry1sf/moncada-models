<span id="newsletter"></span>
<section class="newsletter">
  <div class="newsletter-bg"></div>
  <div class="newsletter-content">
    <div class="newsletter-text">
      <h2>Suscríbete Como Nuestro Cliente</h2>
      <p>
        Recibe ofertas exclusivas, tips de moda y nuevas colecciones primero.
      </p>
    </div>
    <form class="newsletter-form">
      <input type="text" placeholder="Tu Nombre" required class="name-input" />
      <button type="submit" class="subscribe-btn"> Suscribirse 🎁 </button>
    </form>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const newsletter = document.querySelector(".newsletter") as HTMLElement;

    if (newsletter) {
      newsletter.addEventListener("mousemove", (e) => {
        const rect = newsletter.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        newsletter.style.setProperty("--mouse-x", `${x}px`);
        newsletter.style.setProperty("--mouse-y", `${y}px`);
      });
    }
  });
</script>

<script>
  const form = document.querySelector(".newsletter-form") as HTMLFormElement;
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = document.querySelector(".name-input") as HTMLInputElement;
    if (!name.value) return;

    window.open(
      `https://wa.me/573024512965?text=Hola%20${name.value}%20me%20gustaria%20estar%20al%20tanto%20de%20los%20nuevos%20productos%20y%20ofertas`,
      "_blank",
    );
  });
</script>

<style>
  .newsletter {
    position: relative;
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    margin-block: 5rem;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    background: var(--color-cta-dark);
    border: 1px solid var(--color-border);
  }

  /* Dynamic background layer */
  .newsletter-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    background: radial-gradient(
      800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(196, 164, 122, 0.15),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .newsletter:hover .newsletter-bg {
    opacity: 1;
  }

  .newsletter-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: center;
  }

  .newsletter-text h2 {
    margin: 0 0 0.75rem 0;
    color: var(--color-cream);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-family: "Playfair Display", serif;
  }

  .newsletter-text p {
    margin: 0;
    color: var(--color-bg-light);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 300;
    font-family: "Poppins", sans-serif;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
  }

  .name-input {
    flex: 1;
    padding: 0.85rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg-light);
    color: var(--color-text-dark);
    font-size: 0.95rem;
    font-family: "Poppins", sans-serif;
    transition: var(--transition);
  }

  .name-input:focus {
    outline: none;
    background: var(--color-bg-dark);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(196, 164, 122, 0.1);
  }

  .name-input::placeholder {
    color: var(--color-text-light);
  }

  .subscribe-btn {
    padding: 0.85rem 1.8rem;
    background: var(--color-accent);
    color: var(--color-cream);
    border: none;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: var(--transition);
    font-family: "Poppins", sans-serif;
    white-space: nowrap;
  }

  .subscribe-btn:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 900px) {
    .newsletter-content {
      grid-template-columns: 1fr;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .subscribe-btn {
      width: 100%;
    }

    .newsletter {
      padding: 2rem 1.5rem;
      margin: 3rem auto 2rem auto;
      /* width is already handled by the main rule */
    }
  }
</style>
