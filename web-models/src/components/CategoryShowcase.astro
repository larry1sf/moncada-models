---
import Image from "astro/components/Image.astro";
import { categories } from "~/data/categories";
---

<div class="categories-container">
  <section class="categories-grid" id="categories-grid">
    {
      categories.map((category) => (
        <div class="category-item">
          <a href={`/category/${category.slug}`} class="category-card">
            <div class="card-image">
              <Image
                src={category.image.url}
                alt={category.title}
                width={300}
                height={300}
              />
              <div class="overlay">
                <span class="view-btn">Ver Colección</span>
              </div>
            </div>
            <div class="card-content">
              <div class="card-header">
                <h3>{category.title}</h3>
              </div>
              <p class="description">{category.description}</p>
              <div class="card-footer">
                <span class="product-count">
                  {category.productCount} productos
                </span>
                <span class="arrow">→</span>
              </div>
            </div>
          </a>
        </div>
      ))
    }
  </section>

  <div class="pagination-controls" id="pagination-controls">
    <button id="prev-btn" class="pagination-btn" aria-label="Anterior">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <div class="pagination-dots" id="pagination-dots"></div>
    <button id="next-btn" class="pagination-btn" aria-label="Siguiente">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const grid = document.getElementById("categories-grid");
    const items = grid?.querySelectorAll(".category-item");
    const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
    const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
    const dotsContainer = document.getElementById("pagination-dots");

    if (!grid || !items || items.length === 0 || !prevBtn || !nextBtn) return;

    let currentPage = 0;
    let itemsPerPage = 3;
    let totalPages = 0;

    function updateItemsPerPage() {
      const width = window.innerWidth;
      if (width < 640) {
        itemsPerPage = 1;
      } else if (width < 1024) {
        itemsPerPage = 2;
      } else {
        itemsPerPage = 3;
      }
      totalPages = Math.ceil((items?.length || 0) / itemsPerPage);

      // Reset to page 0 if current page is out of bounds
      if (currentPage >= totalPages) {
        currentPage = 0;
      }

      updateDisplay();
    }

    function updateDisplay() {
      // Show/Hide items
      items?.forEach((item, index) => {
        const start = currentPage * itemsPerPage;
        const end = start + itemsPerPage;

        if (index >= start && index < end) {
          (item as HTMLElement).style.display = "block";
          // Add a small animation effect
          (item as HTMLElement).style.animation = "fadeIn 0.5s ease forwards";
        } else {
          (item as HTMLElement).style.display = "none";
        }
      });

      // Update buttons
      prevBtn.disabled = currentPage === 0;
      nextBtn.disabled = currentPage >= totalPages - 1;

      // Update dots
      if (dotsContainer) {
        dotsContainer.innerHTML = "";
        // Only show dots if there's more than one page
        if (totalPages > 1) {
          for (let i = 0; i < totalPages; i++) {
            const dot = document.createElement("span");
            dot.className = `pagination-dot ${i === currentPage ? "active" : ""}`;
            dot.addEventListener("click", () => {
              currentPage = i;
              updateDisplay();
            });
            dotsContainer.appendChild(dot);
          }
        }
      }

      // Hide controls if only one page
      const controls = document.getElementById("pagination-controls");
      if (controls) {
        controls.style.display = totalPages <= 1 ? "none" : "flex";
      }
    }

    // Event Listeners
    prevBtn.addEventListener("click", () => {
      if (currentPage > 0) {
        currentPage--;
        updateDisplay();
      }
    });

    nextBtn.addEventListener("click", () => {
      if (currentPage < totalPages - 1) {
        currentPage++;
        updateDisplay();
      }
    });

    window.addEventListener("resize", () => {
      updateItemsPerPage();
    });

    // Initialize
    updateItemsPerPage();
  });
</script>

<style>
  .categories-container {
    width: 100%;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .category-item {
    height: 100%;
  }

  .category-item a {
    height: 100%;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: var(--transition);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    transform: translateY(0);
    height: 100%;
  }

  .category-card:hover {
    transform: translateY(-12px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    background: var(--color-card-bg-hover);
  }

  .card-image {
    position: relative;
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .category-card:hover .card-image img {
    transform: scale(1.08);
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .category-card:hover .overlay {
    opacity: 1;
  }

  .view-btn {
    background: var(--color-accent);
    color: white;
    padding: 0.8rem 1.8rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    transition: var(--transition);
    box-shadow: var(--shadow-md);
  }

  .category-card:hover .view-btn {
    transform: scale(1.05);
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-lg);
  }

  .card-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .icon {
    font-size: 2.2rem;
    line-height: 1;
  }

  .card-header h3 {
    margin: 0;
    color: var(--color-text-dark);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    font-family: "Playfair Display", serif;
  }

  .description {
    color: var(--color-text-medium);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0 0 1rem 0;
    flex-grow: 1;
    font-family: "Poppins", sans-serif;
    font-weight: 300;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-count {
    color: var(--color-text-medium);
    font-size: 0.9rem;
    font-weight: 500;
    font-family: "Poppins", sans-serif;
  }

  .arrow {
    color: var(--color-accent);
    font-size: 1.3rem;
    transition: var(--transition);
    font-weight: 600;
  }

  .category-card:hover .arrow {
    color: var(--color-accent-hover);
    transform: translateX(4px);
  }

  /* Pagination Styles */
  .pagination-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .pagination-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: white;
    color: var(--color-text-dark);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .pagination-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: white;
    transform: translateY(-2px);
  }

  .pagination-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    border-color: #eee;
    color: #ccc;
  }

  .pagination-dots {
    display: flex;
    gap: 0.5rem;
  }

  :global(.pagination-dot) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-border);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  :global(.pagination-dot.active) {
    background-color: var(--color-accent);
    transform: scale(1.2);
  }

  :global(.pagination-dot:hover:not(.active)) {
    background-color: var(--color-accent-hover);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Grid Overrides */
  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .categories-grid {
      gap: 2rem;
    }

    .card-content {
      padding: 1.5rem;
    }

    .card-image {
      height: 220px;
    }
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .card-header h3 {
      font-size: 1.2rem;
    }

    .description {
      font-size: 0.9rem;
    }
  }
</style>
