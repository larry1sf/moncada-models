<div id="toast-container" class="toast-container">
    <div class="toast-content">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="toast-icon"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
        >
        <span id="toast-message">Mensaje de alerta</span>
    </div>
</div>

<style>
    .toast-container {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: #ffffff;
        color: #5a4a42;
        padding: 1rem 2rem;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(90, 74, 66, 0.15);
        display: flex;
        align-items: center;
        gap: 1rem;
        z-index: 2000;
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid rgba(196, 164, 122, 0.4);
        font-weight: 500;
    }

    .toast-container.active {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
    }

    .toast-content {
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

    .toast-icon {
        color: #c4a47a;
    }

    #toast-message {
        font-weight: 500;
        font-size: 0.95rem;
    }
</style>

<script>
    let cleanup: (() => void) | undefined;

    function initToast() {
        if (cleanup) cleanup();

        const toast = document.getElementById("toast-container");
        const messageSpan = document.getElementById("toast-message");
        let timeoutId: any;

        const handleShowToast = (e: Event) => {
            const customEvent = e as CustomEvent;
            if (!toast || !messageSpan) return;

            messageSpan.textContent = customEvent.detail.message;
            toast.classList.add("active");

            if (timeoutId) clearTimeout(timeoutId);

            timeoutId = setTimeout(() => {
                toast.classList.remove("active");
            }, 3000);
        };

        window.addEventListener("showToast", handleShowToast);

        cleanup = () => {
            window.removeEventListener("showToast", handleShowToast);
            if (timeoutId) clearTimeout(timeoutId);
        };
    }

    // Initialize on page load (covers initial and navigation)
    document.addEventListener("astro:page-load", initToast);
</script>
