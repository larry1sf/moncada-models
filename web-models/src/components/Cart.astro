---
import type { Product } from "../data/products";

export interface CartItem {
  product: Product;
  quantity: number;
}

export interface Props {
  items: CartItem[];
}

const { items } = Astro.props;

const total = items.reduce(
  (sum, item) => sum + item.product.price * item.quantity,
  0,
);
---

<aside class="cart">
  <div class="cart-header">
    <h2>🛍️ Tu Carrito</h2>
    <span class="badge">{items.length}</span>
  </div>

  {
    items.length === 0 ? (
      <div class="empty-cart">
        <p>Tu carrito está vacío 💝</p>
        <span class="text-small">Agrega tus blusas favoritas para empezar</span>
      </div>
    ) : (
      <>
        <ul class="cart-items">
          {items.map((item) => (
            <li class="cart-item">
              <div class="item-info">
                <span class="item-name">{item.product.name}</span>
                <span class="item-qty">Cantidad: x{item.quantity}</span>
              </div>
              <span class="item-price">
                ${(item.product.price * item.quantity).toFixed(2)}
              </span>
            </li>
          ))}
        </ul>

        <div class="cart-summary">
          <div class="summary-row">
            <span>Subtotal:</span>
            <span>${total.toFixed(2)}</span>
          </div>
          <div class="summary-row">
            <span>Envío:</span>
            <span>Gratis</span>
          </div>
          <div class="summary-row total-row">
            <span>Total:</span>
            <span class="total-price">${total.toFixed(2)}</span>
          </div>
        </div>

        <button class="checkout-btn">💳 Ir a Pagar</button>
      </>
    )
  }
</aside>

<style>
  .cart {
    background: linear-gradient(135deg, #ffffff 0%, #fdf8f3 100%);
    border-radius: 1.25rem;
    border: 2px solid #e8d5c4;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 4px 12px rgba(172, 140, 124, 0.12);
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid #f0e8e0;
    padding-bottom: 1rem;
  }

  .cart-header h2 {
    margin: 0;
    color: #5a4a42;
    font-size: 1.3rem;
    font-weight: 700;
  }

  .badge {
    background: linear-gradient(135deg, #c4a47a 0%, #a89080 100%);
    color: white;
    padding: 0.35rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .empty-cart {
    text-align: center;
    padding: 2rem 1rem;
    color: #a89080;
  }

  .empty-cart p {
    margin: 0 0 0.5rem 0;
    font-size: 1.05rem;
    color: #5a4a42;
    font-weight: 500;
  }

  .text-small {
    font-size: 0.9rem;
    color: #a89080;
  }

  .cart-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cart-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
    border-radius: 0.75rem;
    gap: 1rem;
  }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .item-name {
    color: #5a4a42;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .item-qty {
    color: #a89080;
    font-size: 0.85rem;
  }

  .item-price {
    color: #c4a47a;
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
  }

  .cart-summary {
    background: linear-gradient(135deg, #fafaf8 0%, #f5f1e8 100%);
    border-radius: 0.75rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    color: #8a7a72;
    font-size: 0.95rem;
  }

  .total-row {
    border-top: 2px solid #e8d5c4;
    padding-top: 0.75rem;
    margin-top: 0.25rem;
    font-weight: 700;
    color: #5a4a42;
    font-size: 1.1rem;
  }

  .total-price {
    background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .checkout-btn {
    background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
    color: white;
    border: none;
    padding: 0.9rem 1.5rem;
    border-radius: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: "Poppins", sans-serif;
    margin-top: 0.5rem;
  }

  .checkout-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(172, 140, 124, 0.25);
  }
</style>
