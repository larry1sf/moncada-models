---
import { STRAPI_HOST } from "~/services/consts";
import type { Product } from "../data/products";
import Image from "astro/components/Image.astro";
import { traducir } from "~/services/translate";

export interface Props {
  product: Product;
  onAddToCart?: (product: Product) => void;
}

const { product } = Astro.props;
---

<article class="product-card">
  <div class="image-wrapper">
    <Image
      width={300}
      height={300}
      src={`${STRAPI_HOST}${product.images[0].url}`}
      alt={product.name}
      loading="lazy"
    />
    {!product.isActive && <div class="out-of-stock">Agotado</div>}
    {product.texture && <div class="rating">⭐ {product.texture}</div>}
  </div>
  <div class="info">
    <h3>{product.name}</h3>
    <p class="description">{product.description}</p>
    {
      product.size && (
        <div class="colors">
          <span class="label">Talla:</span>
          <div class="color-dots">
            {product.size.map((s) => (
              <span title={s}>{s}</span>
            ))}
          </div>
        </div>
      )
    }
    <div class="footer">
      <p class="price">
        {
          new Intl.NumberFormat("es-CO", {
            style: "currency",
            currency: "COP",
            minimumFractionDigits: 0,
          }).format(product.price)
        }
        Cop
      </p>
      <button disabled={!product.isActive} class="add-to-cart">
        {product.isActive ? "🛍️ Agregar" : "Agotado"}
      </button>
    </div>
  </div>
</article>

<style>
  .product-card {
    background: #ffffff;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(172, 140, 124, 0.12);
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(232, 213, 196, 0.5);
  }

  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 24px rgba(172, 140, 124, 0.18);
    border-color: rgba(200, 160, 140, 0.8);
  }

  .image-wrapper {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
    height: 280px;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-card:hover img {
    transform: scale(1.05);
  }

  .out-of-stock {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(200, 100, 100, 0.9);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
  }

  .rating {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #a89080;
    backdrop-filter: blur(4px);
  }

  .info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    flex-grow: 1;
  }

  .info h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #5a4a42;
    line-height: 1.3;
  }

  .description {
    margin: 0;
    font-size: 0.85rem;
    color: #8a7a72;
    line-height: 1.5;
    flex-grow: 1;
  }

  .colors {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .label {
    color: #a89080;
    font-weight: 500;
  }

  .color-dots {
    display: flex;
    gap: 0.4rem;
  }

  .color-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #c4a47a 0%, #a89080 100%);
    border: 1px solid #e8d5c4;
    display: inline-block;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #f0e8e0;
  }

  .price {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .add-to-cart {
    padding: 0.6rem 1.2rem;
    border-radius: 0.75rem;
    border: none;
    background: linear-gradient(135deg, #e8d5c4 0%, #d4c1b0 100%);
    color: #5a4a42;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    font-family: "Poppins", sans-serif;
  }

  .add-to-cart:hover:not(:disabled) {
    background: linear-gradient(135deg, #d4c1b0 0%, #c4a47a 100%);
    transform: scale(1.05);
  }

  .add-to-cart:disabled {
    background: #e8ddd2;
    color: #a89080;
    cursor: not-allowed;
    opacity: 0.6;
  }
</style>
