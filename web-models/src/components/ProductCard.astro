---
import { STRAPI_HOST } from "~/services/consts";
import Image from "astro/components/Image.astro";
import type { ProductAttributes } from "~/types/product";

export interface Props {
  product: ProductAttributes;
}

const { product } = Astro.props;
---

<a href={`/product/${product.slug}`} class="product-card">
  <div class="product-image">
    {product.isActive && <div class="product-badge">Disponible</div>}
    {
      !product.isActive && (
        <div class="product-badge out-of-stock-badge">Agotado</div>
      )
    }
    <Image
      width={400}
      height={500}
      src={`${STRAPI_HOST}${product?.images?.length ? product?.images[0]?.url : ""}`}
      alt={product.name}
      loading="lazy"
      transition:name={`image-${product.slug}`}
    />
  </div>
  <div class="product-info">
    <h3>{product.name}</h3>
    <p class="product-description">{product.description}</p>
    <div class="product-footer">
      <span class="product-price">
        {
          new Intl.NumberFormat("es-CO", {
            style: "currency",
            currency: "COP",
            minimumFractionDigits: 0,
          }).format(product.price)
        }
      </span>
      <button class="add-to-cart">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path
            d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</a>

<style>
  .product-card {
    background: var(--color-card-bg);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: var(--transition);
    position: relative;
    box-shadow: var(--shadow-md);
    text-decoration: none;
    display: block;
  }

  .product-card:hover {
    transform: translateY(-12px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    background: var(--color-card-bg-hover);
  }

  .product-image {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.08);
  }

  .product-image::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.1) 100%
    );
    pointer-events: none;
  }

  .product-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-hover) 100%
    );
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
    box-shadow: var(--shadow-md);
  }

  .out-of-stock-badge {
    background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
  }

  .product-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-info h3 {
    margin: 0;
    color: var(--color-text-dark);
    font-family: "Playfair Display", serif;
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.02em;
  }

  .product-description {
    margin: 0;
    color: var(--color-text-medium);
    font-size: 0.9rem;
    line-height: 1.5;
    font-family: "Poppins", sans-serif;
    font-weight: 300;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .product-price {
    color: var(--color-accent);
    font-size: 1.5rem;
    font-weight: 700;
    font-family: "Playfair Display", serif;
  }

  .add-to-cart {
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-hover) 100%
    );
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    color: white;
    box-shadow: var(--shadow-sm);
  }

  .add-to-cart:hover {
    transform: scale(1.1) rotate(12deg);
    box-shadow: var(--shadow-md);
    background: linear-gradient(
      135deg,
      var(--color-accent-hover) 0%,
      var(--color-accent) 100%
    );
  }

  .add-to-cart:active {
    transform: scale(0.95);
  }
</style>
