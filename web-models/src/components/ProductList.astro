---
import { products as allProducts } from "../data/products";
import CardsProducts from "./CardsProducts.astro";
import ProductCard from "./ProductCard.astro";

type Props = {
  products?: typeof allProducts;
};
const { products = allProducts } = Astro.props;
---

<section class="product-list">
  {
    products.map(({ name, slug, price, description, images }) => (
      <CardsProducts
        title={name}
        slug={slug}
        price={price}
        description={description}
        images={images}
      />
    ))
  }
</section>

<style>
  .product-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .product-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
