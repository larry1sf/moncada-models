---
export const prerender = true;
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Registros de Pedidos - Admin | Moncada Models">
    <div class="admin-page">
        <!-- Login Form (shown when not authenticated) -->
        <div class="login-container" id="login-container">
            <div class="login-card">
                <h1>Acceso Administrativo</h1>
                <p>
                    Ingrese sus credenciales para ver los registros de pedidos
                </p>

                <form id="login-form" class="login-form">
                    <div class="form-group">
                        <label for="username">Usuario</label>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            required
                            autocomplete="username"
                        />
                    </div>

                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            required
                            autocomplete="current-password"
                        />
                    </div>

                    <div class="error-message" id="login-error"></div>

                    <button type="submit" class="btn-primary"
                        >Iniciar Sesión</button
                    >
                </form>
            </div>
        </div>

        <!-- Orders Dashboard (shown when authenticated) -->
        <div
            class="dashboard-container"
            id="dashboard-container"
            style="display: none;"
        >
            <div class="dashboard-header">
                <h1>Registros de Pedidos</h1>
                <button class="btn-secondary" id="logout-btn"
                    >Cerrar Sesión</button
                >
            </div>

            <div class="orders-stats">
                <div class="stat-card">
                    <span class="stat-label">Total de Pedidos</span>
                    <span class="stat-value" id="total-orders">0</span>
                </div>
            </div>

            <div class="orders-container" id="orders-container">
                <p class="empty-state">No hay pedidos registrados</p>
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    import { formatPriceCOP } from "~/services/consts";

    const STRAPI_HOST = "http://localhost:1337";
    const AUTH_KEY = "adminAuth";
    const ORDERS_KEY = "orders";
    const SESSION_DURATION = 24 * 60 * 60 * 1000; // 24 hours in milliseconds

    // Admin credentials
    const ADMIN_USERNAME = "admin";
    const ADMIN_PASSWORD = "admin1324*";

    // DOM elements
    const loginContainer = document.getElementById(
        "login-container",
    ) as HTMLElement;
    const dashboardContainer = document.getElementById(
        "dashboard-container",
    ) as HTMLElement;
    const loginForm = document.getElementById("login-form") as HTMLFormElement;
    const loginError = document.getElementById("login-error") as HTMLElement;
    const logoutBtn = document.getElementById(
        "logout-btn",
    ) as HTMLButtonElement;
    const ordersContainer = document.getElementById(
        "orders-container",
    ) as HTMLElement;
    const totalOrdersEl = document.getElementById(
        "total-orders",
    ) as HTMLElement;

    // Check if user is authenticated
    function isAuthenticated(): boolean {
        const authData = localStorage.getItem(AUTH_KEY);
        if (!authData) return false;

        try {
            const { timestamp } = JSON.parse(authData);
            const now = Date.now();

            // Check if session has expired (24 hours)
            if (now - timestamp > SESSION_DURATION) {
                localStorage.removeItem(AUTH_KEY);
                return false;
            }

            return true;
        } catch {
            return false;
        }
    }

    // Set authentication
    function setAuthentication() {
        const authData = {
            timestamp: Date.now(),
            authenticated: true,
        };
        localStorage.setItem(AUTH_KEY, JSON.stringify(authData));
    }

    // Clear authentication
    function clearAuthentication() {
        localStorage.removeItem(AUTH_KEY);
    }

    // Get all orders from localStorage
    function getOrders() {
        try {
            const orders = localStorage.getItem(ORDERS_KEY);
            return orders ? JSON.parse(orders) : [];
        } catch {
            return [];
        }
    }

    // Render orders
    function renderOrders() {
        const orders = getOrders();

        if (orders.length === 0) {
            ordersContainer.innerHTML =
                '<p class="empty-state">No hay pedidos registrados</p>';
            totalOrdersEl.textContent = "0";
            return;
        }

        totalOrdersEl.textContent = orders.length.toString();

        let html = "";
        orders.reverse().forEach((order: any, index: number) => {
            const orderDate = new Date(order.timestamp);
            const products = order.products || [];
            const total = products.reduce(
                (sum: number, p: any) => sum + p.price * p.quantity,
                0,
            );

            html += `
                <div class="order-card">
                    <div class="order-header">
                        <div class="order-info">
                            <span class="order-number">Pedido #${orders.length - index}</span>
                            <span class="order-date">${orderDate.toLocaleString(
                                "es-CO",
                                {
                                    dateStyle: "medium",
                                    timeStyle: "short",
                                },
                            )}</span>
                        </div>
                        <span class="order-total">${formatPriceCOP(total)} COP</span>
                    </div>
                    
                    <div class="order-details">
                        <div class="detail-row">
                            <strong>Cliente:</strong>
                            <span>${order.fullname || "-"}</span>
                        </div>
                        <div class="detail-row">
                            <strong>Teléfono:</strong>
                            <span>${order.phone || "-"}</span>
                        </div>
                        ${
                            order.email
                                ? `
                            <div class="detail-row">
                                <strong>Email:</strong>
                                <span>${order.email}</span>
                            </div>
                        `
                                : ""
                        }
                        <div class="detail-row">
                            <strong>Dirección:</strong>
                            <span>${order.address || "-"}</span>
                        </div>
                        <div class="detail-row">
                            <strong>Fecha de Entrega:</strong>
                            <span>${
                                order.deliveryDate
                                    ? new Date(
                                          order.deliveryDate,
                                      ).toLocaleString("es-CO", {
                                          dateStyle: "medium",
                                          timeStyle: "short",
                                      })
                                    : "-"
                            }</span>
                        </div>
                        <div class="detail-row">
                            <strong>Envío:</strong>
                            <span>${order.shipping === "nacional" ? "Nacional" : "Internacional"}</span>
                        </div>
                        <div class="detail-row">
                            <strong>Método de Pago:</strong>
                            <span>${order.payment || "-"}</span>
                        </div>
                    </div>

                    <div class="order-products">
                        <strong>Productos (${products.length}):</strong>
                        <div class="products-list">
                            ${products
                                .map(
                                    (p: any) => `
                                <div class="product-item">
                                    ${p.image ? `<img src="${p.image.startsWith("http") ? p.image : STRAPI_HOST + p.image}" alt="${p.name}" />` : '<div class="placeholder"></div>'}
                                    <div class="product-info">
                                        <span class="product-name">${p.name}</span>
                                        <span class="product-details">
                                            ${p.size ? `Talla: ${p.size}` : ""} 
                                            ${p.color ? `| ${p.color}` : ""}
                                        </span>
                                        <span class="product-qty">Cantidad: ${p.quantity}</span>
                                    </div>
                                    <span class="product-price">${formatPriceCOP(p.price * p.quantity)} COP</span>
                                </div>
                            `,
                                )
                                .join("")}
                        </div>
                    </div>
                </div>
            `;
        });

        ordersContainer.innerHTML = html;
    }

    // Handle login
    loginForm.addEventListener("submit", (e) => {
        e.preventDefault();

        const username = (
            document.getElementById("username") as HTMLInputElement
        ).value;
        const password = (
            document.getElementById("password") as HTMLInputElement
        ).value;

        if (username === ADMIN_USERNAME && password === ADMIN_PASSWORD) {
            setAuthentication();
            loginContainer.style.display = "none";
            dashboardContainer.style.display = "block";
            renderOrders();
            loginError.textContent = "";
        } else {
            loginError.textContent = "Usuario o contraseña incorrectos";
        }
    });

    // Handle logout
    logoutBtn.addEventListener("click", () => {
        clearAuthentication();
        loginContainer.style.display = "flex";
        dashboardContainer.style.display = "none";
        loginForm.reset();
    });

    // Initialize on load
    if (isAuthenticated()) {
        loginContainer.style.display = "none";
        dashboardContainer.style.display = "block";
        renderOrders();
    }

    // Listen for new orders (in case another tab submits)
    window.addEventListener("storage", (e) => {
        if (e.key === ORDERS_KEY && isAuthenticated()) {
            renderOrders();
        }
    });
</script>

<style>
    .admin-page {
        min-height: 90vh;
        padding: 2rem;
        background: linear-gradient(135deg, #faf9f7 0%, #f5f3f0 100%);
    }

    /* Login Styles */
    .login-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
    }

    .login-card {
        background: white;
        padding: 3rem;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        max-width: 450px;
        width: 100%;
    }

    .login-card h1 {
        font-family: "Playfair Display", serif;
        font-size: 2rem;
        color: var(--color-text-dark);
        margin-bottom: 0.5rem;
        text-align: center;
    }

    .login-card > p {
        color: var(--color-text-medium);
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-form .form-group {
        margin-bottom: 1.5rem;
    }

    .login-form label {
        display: block;
        font-weight: 600;
        color: var(--color-text-dark);
        margin-bottom: 0.5rem;
    }

    .login-form input {
        width: 100%;
        padding: 0.95rem 1.25rem;
        border: 2px solid rgba(196, 164, 122, 0.25);
        border-radius: 8px;
        font-size: 1rem;
        font-family: "Poppins", sans-serif;
        background: #faf9f7;
        transition: all 0.3s ease;
    }

    .login-form input:focus {
        outline: none;
        border-color: var(--color-accent);
        background: white;
        box-shadow: 0 0 0 3px rgba(196, 164, 122, 0.1);
    }

    .error-message {
        color: #d32f2f;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        min-height: 1.2rem;
    }

    .btn-primary,
    .btn-secondary {
        width: 100%;
        padding: 1rem 2rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: "Poppins", sans-serif;
    }

    .btn-primary {
        background: linear-gradient(135deg, #c4a47a 0%, #a89080 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-secondary {
        background: white;
        color: var(--color-text-dark);
        border: 2px solid rgba(196, 164, 122, 0.3);
    }

    .btn-secondary:hover {
        border-color: var(--color-accent);
        background: #faf9f7;
    }

    /* Dashboard Styles */
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .dashboard-header h1 {
        font-family: "Playfair Display", serif;
        font-size: 2.5rem;
        color: var(--color-text-dark);
    }

    .dashboard-header .btn-secondary {
        width: auto;
        padding: 0.75rem 1.5rem;
    }

    .orders-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: var(--shadow-md);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .stat-label {
        font-size: 0.9rem;
        color: var(--color-text-medium);
        font-weight: 500;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-accent);
    }

    .orders-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .empty-state {
        text-align: center;
        color: var(--color-text-medium);
        padding: 3rem;
        background: white;
        border-radius: 12px;
    }

    :global(.order-card) {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-md);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    :global(.order-card:hover) {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    :global(.order-header) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid rgba(196, 164, 122, 0.2);
        flex-wrap: wrap;
        gap: 1rem;
    }

    :global(.order-info) {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    :global(.order-number) {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text-dark);
    }

    :global(.order-date) {
        font-size: 0.9rem;
        color: var(--color-text-medium);
    }

    :global(.order-total) {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-accent);
    }

    :global(.order-details) {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    :global(.detail-row) {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    :global(.detail-row strong) {
        font-size: 0.85rem;
        color: var(--color-text-medium);
        font-weight: 600;
    }

    :global(.detail-row span) {
        color: var(--color-text-dark);
    }

    :global(.order-products) {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 2px solid rgba(196, 164, 122, 0.2);
    }

    :global(.order-products > strong) {
        display: block;
        margin-bottom: 1rem;
        color: var(--color-text-dark);
    }

    :global(.products-list) {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    :global(.product-item) {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #faf9f7;
        border-radius: 8px;
    }

    :global(.product-item img),
    :global(.product-item .placeholder) {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        background: rgba(196, 164, 122, 0.1);
    }

    :global(.product-info) {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    :global(.product-name) {
        font-weight: 600;
        color: var(--color-text-dark);
    }

    :global(.product-details),
    :global(.product-qty) {
        font-size: 0.85rem;
        color: var(--color-text-medium);
    }

    :global(.product-qty strong) {
        color: var(--color-text-dark);
    }

    :global(.product-price) {
        font-weight: 700;
        color: var(--color-accent);
        white-space: nowrap;
    }

    @media (max-width: 768px) {
        .dashboard-header h1 {
            font-size: 2rem;
        }

        :global(.order-header) {
            flex-direction: column;
            align-items: flex-start;
        }

        :global(.product-item) {
            flex-direction: column;
            align-items: flex-start;
        }

        :global(.product-price) {
            align-self: flex-end;
        }
    }
</style>
