<style>
    /* Order Summary Styles */
    .order-summary {
        background: #faf9f7;
        border-radius: 12px;
        padding: 2rem;
        margin-top: 1rem;
        border: 1px solid rgba(196, 164, 122, 0.2);
    }

    .order-summary h3 {
        font-family: "Playfair Display", serif;
        color: var(--color-text-dark);
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        text-align: center;
    }

    .summary-products {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    :global(.summary-product-item) {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    :global(.summary-product-item:last-child) {
        border-bottom: none;
        padding-bottom: 0;
    }

    :global(.summary-product-image) {
        position: relative;
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.1);
        flex-shrink: 0;
    }

    :global(.summary-product-image img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    :global(.summary-product-qty) {
        position: absolute;
        top: -5px;
        right: -5px;
        background: var(--color-accent);
        color: white;
        font-size: 0.7rem;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    :global(.summary-product-details) {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    :global(.summary-product-name) {
        font-weight: 600;
        color: var(--color-text-dark);
        font-size: 0.95rem;
    }

    :global(.summary-product-meta) {
        font-size: 0.8rem;
        color: var(--color-text-medium);
    }

    :global(.summary-product-price) {
        font-weight: 600;
        color: var(--color-text-dark);
        font-size: 0.95rem;
    }

    .summary-divider {
        height: 1px;
        background: rgba(196, 164, 122, 0.3);
        margin: 1.5rem 0;
    }

    .summary-details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .summary-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .summary-item.full-width {
        grid-column: span 2;
    }

    .summary-label {
        font-size: 0.8rem;
        color: var(--color-text-medium);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .summary-value {
        font-weight: 500;
        color: var(--color-text-dark);
        font-size: 0.95rem;
    }

    .summary-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.5rem;
    }

    .summary-total-label {
        font-family: "Playfair Display", serif;
        font-size: 1.25rem;
        color: var(--color-text-dark);
    }

    .summary-total-value {
        font-family: "Playfair Display", serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-accent);
    }

    @media (max-width: 600px) {
        .summary-details-grid {
            grid-template-columns: 1fr;
        }

        .summary-item.full-width {
            grid-column: span 1;
        }
    }
</style>
