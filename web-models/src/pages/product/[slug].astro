---
import Image from "astro/components/Image.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Toast from "~/components/Toast.astro";
import AnotherCategories from "~/components/AnotherCategories.astro";
import ProductRelationated from "~/components/ProductRelationated.astro";
import { products } from "~/data/products";

const { slug } = Astro.params;
if (!slug) return "No tienes un slug";
export const getStaticPaths = async () => {
  return products.map((product) => ({
    params: {
      slug: product.slug,
    },
  }));
};
const product = products.find((product) => product.slug === slug);
if (!product) return "Producto no encontrado";
---

<script>
  function setupSelection() {
    const buttonSendCart = document.querySelector(
      ".add-to-cart-btn",
    ) as HTMLButtonElement | null;
    const productData = buttonSendCart?.dataset?.product;
    const product = productData ? JSON.parse(productData) : null;
    const selectedSize = document.querySelectorAll(".size-btn");
    const selectedColor = document.querySelectorAll(".color-btn");

    if (!buttonSendCart || !product) return;

    let valueSize, valueColor;
    function updateDataset() {
      if (buttonSendCart) {
        buttonSendCart.dataset.product = JSON.stringify(product);
      }
      // console.log(product);
    }
    function selectSize(e: Event) {
      const clicked = e.currentTarget as HTMLButtonElement;
      selectedSize.forEach((s) => s.classList.remove("active"));
      clicked.classList.add("active");
      valueSize = clicked.innerText.trim();
      product.size = valueSize;
      updateDataset();
    }

    function selectColor(e: Event) {
      const clicked = e.currentTarget as HTMLButtonElement;
      selectedColor.forEach((s) => s.classList.remove("active"));
      clicked.classList.add("active");
      valueColor = clicked.innerText.trim();
      product.color = valueColor;
      updateDataset();
    }

    selectedColor.forEach((color) => {
      color.addEventListener("click", selectColor);
    });

    selectedSize.forEach((size) => {
      size.addEventListener("click", selectSize);
    });
  }
  function setupAddToCard() {
    type Product = {
      name: string;
      size: string | null;
      color: string | null;
      image: string;
      price: number;
      quantity: number;
    };

    type CartItem = {
      name: string;
      size: string | null;
      color: string | null;
      image: string;
      price: number;
      quantity: number;
    };

    const addToCartBtn = document.querySelector(
      ".add-to-cart-btn",
    ) as HTMLButtonElement | null;
    const quantityDisplay = document.querySelector(
      "#counter-quantity",
    ) as HTMLElement | null;

    // 1) Función para actualizar el carrito en localStorage
    // 1) Función para actualizar el carrito en localStorage
    function addToCart(product: Product, quantity: number) {
      if (!product || !product.size || !product.color) return;

      const cart = JSON.parse(
        localStorage.getItem("cart") || "[]",
      ) as CartItem[];

      const normalize = (str: string | null) => (str ? str.trim() : null);

      const pName = normalize(product.name);
      const pSize = normalize(product.size);
      const pColor = normalize(product.color);

      const existingItemIndex = cart.findIndex((item) => {
        const iName = normalize(item.name);
        const iSize = normalize(item.size);
        const iColor = normalize(item.color);

        return (
          iName === pName &&
          (!pSize || iSize === pSize) &&
          (!pColor || iColor === pColor)
        );
      });

      if (existingItemIndex !== -1) {
        cart[existingItemIndex].quantity += quantity;
      } else {
        cart.push({
          ...product,
          size: pSize,
          color: pColor,
          quantity,
        });
      }

      localStorage.setItem("cart", JSON.stringify(cart));
    }

    // 2) Click del botón → actualiza LS y luego dispara evento
    addToCartBtn?.addEventListener("click", () => {
      const quantity = parseInt(quantityDisplay?.innerText || "1");
      const productData = addToCartBtn.dataset.product;
      const product = productData ? (JSON.parse(productData) as Product) : null;

      // Validation: Check if size and color are selected
      if (!product || !product.size || !product.color) {
        window.dispatchEvent(
          new CustomEvent("showToast", {
            detail: {
              message: "Por favor selecciona una talla y un color",
            },
          }),
        );
        return;
      }

      // Actualizar localStorage primero
      addToCart(product, quantity);

      // Notificar que el carrito ha sido actualizado
      window.dispatchEvent(
        new CustomEvent("cartUpdated", {
          detail: {
            product,
            quantity,
          },
        }),
      );

      window.dispatchEvent(
        new CustomEvent("showToast", {
          detail: {
            message: `${
              quantity > 1
                ? `Se agregaron ${quantity} productos al carrito`
                : "Se agregó un producto al carrito"
            }`,
          },
        }),
      );
    });
  }

  // Map to store event handlers (avoids TypeScript errors with __handler__)
  const quantityHandlers = new Map();

  function setupQuantityButtons() {
    // First, find the quantity container to scope our button selection
    const quantityContainer = document.querySelector(".quantity-container");
    const quantityDisplay = document.querySelector("#counter-quantity");

    console.log("🔧 setupQuantityButtons called");
    console.log("Container found:", quantityContainer);
    console.log("Display found:", quantityDisplay);

    if (!quantityContainer || !quantityDisplay) {
      console.warn("⚠️ Quantity container or display not found!");
      return;
    }

    // Select buttons ONLY within the quantity-container
    const buttons = quantityContainer.querySelectorAll(".quantity-btn");
    console.log("Buttons found in container:", buttons.length);

    if (buttons.length < 2) {
      console.warn("⚠️ Not enough quantity buttons found!");
      return;
    }

    const [restarQuantity, sumarQuantity] = buttons;

    const updateQuantity = (change: number) => {
      const currentText = quantityDisplay.textContent || "1";
      let currentQuantity = parseInt(currentText);
      if (isNaN(currentQuantity)) currentQuantity = 1;
      let newQuantity = currentQuantity + change;

      if (newQuantity < 1) newQuantity = 1;
      else if (newQuantity > 100) newQuantity = 100;

      quantityDisplay.textContent = newQuantity.toString();
      console.log(`✅ Quantity updated: ${currentQuantity} → ${newQuantity}`);
    };

    // Remove existing listeners to prevent duplicates
    const existingRestarHandler = quantityHandlers.get(restarQuantity);
    const existingSumarHandler = quantityHandlers.get(sumarQuantity);

    if (existingRestarHandler) {
      restarQuantity.removeEventListener("click", existingRestarHandler);
      console.log("🗑️ Removed old restar handler");
    }
    if (existingSumarHandler) {
      sumarQuantity.removeEventListener("click", existingSumarHandler);
      console.log("🗑️ Removed old sumar handler");
    }

    const restarHandler = () => {
      console.log("➖ Restar clicked");
      updateQuantity(-1);
    };
    const sumarHandler = () => {
      console.log("➕ Sumar clicked");
      updateQuantity(1);
    };

    restarQuantity.addEventListener("click", restarHandler);
    sumarQuantity.addEventListener("click", sumarHandler);

    // Store handlers in Map for future cleanup
    quantityHandlers.set(restarQuantity, restarHandler);
    quantityHandlers.set(sumarQuantity, sumarHandler);

    console.log("✅ Quantity buttons setup complete");
  }

  function setupGallery() {
    const mainImage = document.getElementById("main-image") as HTMLImageElement;
    const thumbnails = document.querySelectorAll(".thumbnail");

    if (!mainImage || thumbnails.length === 0) return;

    thumbnails.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const newUrl = thumb.getAttribute("data-url");
        if (!newUrl || mainImage.src.includes(newUrl)) return;

        // 1. Start blur
        mainImage.style.filter = "blur(10px)";
        mainImage.style.transition = "filter 0.3s ease";

        // 2. Wait for blur to establish, then swap
        setTimeout(() => {
          mainImage.src = newUrl;

          // 3. When new image loads, remove blur
          mainImage.onload = () => {
            mainImage.style.filter = "blur(0)";
          };
        }, 200);
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    setupSelection();
    setupAddToCard();
    setupQuantityButtons();
    setupGallery();
  });
</script>

<BaseLayout
  title={`${product?.name} | Moda y Estilo Exclusivo | Moncada Models`}
  description={`Compra ${product?.name} en Moncada Models. ${product?.description?.slice(0, 150)}... Descubre la mejor calidad en moda con envíos a todo el país. ¡Haz tu pedido ahora!`}
>
  <section class="product-container">
    <div class="product-wrapper">
      <article class="product-gallery">
        <div class="main-image">
          <Image
            id="main-image"
            transition:name={product.slug}
            src={product?.images[0]?.url}
            alt={product?.name ?? ""}
            width={500}
            height={700}
            transition:name={`image-${product?.slug}`}
          />
        </div>
        {
          product?.images?.length > 1 && (
            <div class="thumbnails">
              {product.images.map((img) => (
                <div class="thumbnail" data-url={img.url}>
                  <Image
                    src={img.url}
                    alt={product.name}
                    width={100}
                    height={100}
                  />
                </div>
              ))}
            </div>
          )
        }
      </article>

      <article class="product-info">
        <nav class="breadcrumbs">
          <a href="/">Inicio</a>
          <span class="separator">/</span>
          <a href="/categories">Categorías</a>
          <span class="separator">/</span>
          <a href={`/category/${product?.product_category?.slug}`}
            >{product?.product_category?.slug}</a
          >
        </nav>

        <h1 class="product-title">{product?.name}</h1>

        <div class="price-container">
          <span class="product-price">
            {
              new Intl.NumberFormat("es-CO", {
                style: "currency",
                currency: "COP",
                minimumFractionDigits: 0,
              }).format(product?.price)
            }
          </span>
          {!product?.isActive && <span class="out-of-stock">Agotado</span>}
        </div>

        <p class="description">{product?.description}</p>

        {
          product?.size && (
            <div class="options-section">
              <h3>Tallas Disponibles</h3>
              <div class="options-grid">
                {Array.isArray(product?.size) ? (
                  product?.size.map((s) => (
                    <button class="option-btn size-btn">{s}</button>
                  ))
                ) : (
                  <button class="option-btn size-btn">{product?.size}</button>
                )}
              </div>
            </div>
          )
        }
        {
          product?.texture && (
            <div class="options-section">
              <h3>Texturas Disponibles</h3>
              {product?.texture && (
                <div class="details-box">
                  <p>Textura: {product?.texture}</p>
                </div>
              )}
            </div>
          )
        }

        {
          product?.color && (
            <div class="options-section">
              <h3>Colores</h3>
              <div class="options-grid">
                {Array.isArray(product?.color) ? (
                  product?.color?.map((c) => (
                    <button class="option-btn color-btn">{c}</button>
                  ))
                ) : (
                  <button class="option-btn color-btn">{product?.color}</button>
                )}
              </div>
            </div>
          )
        }

        <div class="actions">
          <button
            data-product={JSON.stringify({
              name: product.name,
              size: null,
              color: null,
              image: product.images[0].url,
              price: product.price,
              quantity: 1,
            })}
            class="add-to-cart-btn"
            disabled={!product?.isActive}
          >
            {product?.isActive ? "Añadir al Carrito" : "Agotado"}
          </button>
          <div class="quantity-container">
            <button class="quantity-btn" type="button">
              <i>-</i>
            </button>
            <span id="counter-quantity">1</span>
            <button class="quantity-btn" type="button">
              <i>+</i>
            </button>
          </div>
        </div>
      </article>
    </div>
  </section>
  <ProductRelationated product={product} />

  <div class="category-container">
    <AnotherCategories slug={slug} />
  </div>
</BaseLayout>
<Toast />

<style>
  .size-btn.active,
  .color-btn.active {
    background-color: var(--color-bg-dark);
    border-color: var(--color-accent);
    color: var(--color-text-dark);
    font-weight: 500;
  }
</style>

<style>
  .product-price {
    color: var(--color-text-dark);
    font-size: 2rem;
    font-weight: 700;
    font-family: "Playfair Display", serif;
  }
  .product-info {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .product-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .product-gallery {
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .main-image {
    width: 100%;
    border-radius: 1.5rem;
    overflow: hidden;
    background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
    border: 1px solid rgba(232, 213, 196, 0.5);
  }

  .main-image img {
    width: 100%;
    height: auto;
    min-height: 700px;
    max-height: 700px;
    display: block;
    object-fit: cover;
  }

  .thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.5rem;
    justify-items: center;
    /* display: flex;
    gap: 1rem;
    overflow-x: auto; */
    /* padding-bottom: 0.5rem; */
  }

  .thumbnail {
    width: 80px;
    height: 80px;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .thumbnail:hover {
    border-color: #c4a47a;
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: #8a7a72;
  }

  .breadcrumbs a {
    color: #8a7a72;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .breadcrumbs a:hover {
    color: #c4a47a;
  }

  .separator {
    color: #e8d5c4;
  }

  .product-title {
    font-size: 2.5rem;
    color: #5a4a42;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .price-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .out-of-stock {
    background: #ffe5e5;
    color: #d32f2f;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .description {
    color: #8a7a72;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    font-size: 1.2rem;
  }

  .options-section {
    margin-bottom: 2rem;
  }

  .options-section h3 {
    font-size: 1.3rem;
    color: #5a4a42;
    margin: 0 0 0.8rem 0;
    font-weight: 600;
  }

  .options-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .option-btn {
    padding: 0.6rem 1.2rem;
    border: 1px solid #e8d5c4;
    background: white;
    border-radius: 0.75rem;
    color: #5a4a42;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    font-size: 1.05rem;
  }

  .option-btn:hover {
    border-color: #c4a47a;
    background: #fcfbf9;
  }

  .option-btn.selected {
    background: #5a4a42;
    color: white;
    border-color: #5a4a42;
  }

  .actions {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .actions .quantity-container {
    background-color: var(--color-text-dark);
    height: 100%;
    padding: 0 1.2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    border-radius: 1rem;
  }
  #counter-quantity {
    font-weight: 700;
    color: var(--color-cream);
    font-size: 1.2rem;
    min-width: 2rem;
    text-align: center;
  }
  .actions .quantity-container .quantity-btn {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid #e8d5c4;
    background: white;
    font-weight: 600;
    color: var(--color-text-dark);
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }
  .quantity-btn:hover {
    background: #e8ddd2;
    color: #5a4a42;
  }
  .add-to-cart-btn {
    width: 100%;
    padding: 1.2rem;
    background: linear-gradient(135deg, #5a4a42 0%, #4a3a32 100%);
    color: white;
    border: none;
    border-radius: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 8px 20px rgba(90, 74, 66, 0.2);
  }

  .add-to-cart-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(90, 74, 66, 0.3);
  }

  .add-to-cart-btn:disabled {
    background: #e8ddd2;
    cursor: not-allowed;
    box-shadow: none;
  }

  .details-box {
    background: #fcfbf9;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid #f0e8e0;
  }

  .details-box h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #5a4a42;
  }

  .details-box p {
    margin: 0;
    color: #8a7a72;
  }

  /* SEO Features Section */
  .product-features-seo {
    background: white;
    padding: 5rem 2rem;
    margin: 4rem 0;
    border-radius: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  .features-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .features-header h2 {
    font-family: "Playfair Display", serif;
    font-size: 2.5rem;
    color: #5a4a42;
    margin-bottom: 1rem;
  }

  .features-header p {
    color: #8a7a72;
    font-size: 1.1rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .feature-item {
    text-align: center;
    padding: 2rem;
    transition: transform 0.3s ease;
  }

  .feature-item:hover {
    transform: translateY(-8px);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .feature-item h3 {
    font-size: 1.4rem;
    color: #5a4a42;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .feature-item p {
    color: #8a7a72;
    line-height: 1.7;
  }

  @media (max-width: 1135px) {
    .product-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .product-wrapper .product-gallery {
      max-width: none;
    }
    .product-title {
      font-size: 2rem;
    }

    .product-container {
      padding: 1rem;
    }
    .main-image img {
      min-height: auto;
      max-height: auto;
    }
  }
</style>

<style>
  .category-container {
    margin-inline: 3rem;
  }
  @media (max-width: 1135px) {
    .category-container {
      margin-inline: 1rem;
      margin-top: 1.5rem;
    }
  }
  @media (0px<= width <= 500px) {
    .actions {
      flex-wrap: wrap;
    }
    .actions .quantity-container {
      height: auto !important;
      justify-content: center;
      width: 100%;
      padding: 1rem !important;
    }
  }
</style>
