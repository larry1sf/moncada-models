---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteInfo } from "../data/siteInfo";

const pageTitle = "Contacto | Moncada Models";
---

<BaseLayout title={pageTitle}>
    <!-- Hero Section -->
    <section class="contact-hero">
        <div class="hero-content text-center">
            <div class="hero-decoration-top"></div>
            <span class="eyebrow">Atención Exclusiva</span>
            <h1>Hablemos de Estilo</h1>
            <p class="hero-description">
                Tu elegancia es nuestra inspiración. Estamos aquí para
                asesorarte y brindarte una experiencia de compra inigualable.
            </p>
            <div class="hero-decoration-bottom"></div>
        </div>
        <div class="hero-bg-accent"></div>
    </section>

    <div class="contact-container">
        <!-- Main Info Grid -->
        <div class="contact-grid">
            <!-- Contact Info Card -->
            <div class="info-card fade-in-up">
                <div class="card-header">
                    <h2>Canales de Atención</h2>
                    <p>
                        Elige el medio que prefieras. Siempre estamos listos
                        para escucharte.
                    </p>
                </div>

                <div class="info-list">
                    <a
                        href={`tel:${siteInfo.contact.phoneClean}`}
                        class="info-item"
                    >
                        <div class="icon-box">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                ></path></svg
                            >
                        </div>
                        <div class="info-text">
                            <h3>Línea Directa</h3>
                            <span class="info-value"
                                >{siteInfo.contact.phone}</span
                            >
                            <span class="info-sub"
                                >{siteInfo.contact.hours}</span
                            >
                        </div>
                        <div class="arrow-icon">→</div>
                    </a>

                    <a
                        href={`mailto:${siteInfo.contact.email}`}
                        class="info-item"
                    >
                        <div class="icon-box">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect><path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path></svg
                            >
                        </div>
                        <div class="info-text">
                            <h3>Correo Electrónico</h3>
                            <span class="info-value"
                                >{siteInfo.contact.email}</span
                            >
                            <span class="info-sub">Respuesta prioritaria</span>
                        </div>
                        <div class="arrow-icon">→</div>
                    </a>

                    <div class="info-item static">
                        <div class="icon-box">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                                ></path><circle cx="12" cy="10" r="3"
                                ></circle></svg
                            >
                        </div>
                        <div class="info-text">
                            <h3>Boutique Principal</h3>
                            <span class="info-value"
                                >{siteInfo.contact.address}</span
                            >
                            <span class="info-sub">{siteInfo.contact.city}</span
                            >
                        </div>
                    </div>
                </div>

                <div class="social-connect">
                    <h3>Síguenos en Redes</h3>
                    <div class="social-icons">
                        <a
                            href={siteInfo.social.instagram}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Instagram"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="22"
                                height="22"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    width="20"
                                    height="20"
                                    x="2"
                                    y="2"
                                    rx="5"
                                    ry="5"></rect><path
                                    d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                                ></path><line
                                    x1="17.5"
                                    x2="17.51"
                                    y1="6.5"
                                    y2="6.5"></line></svg
                            >
                        </a>
                        <a
                            href={siteInfo.social.facebook}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Facebook"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="22"
                                height="22"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                                ></path></svg
                            >
                        </a>
                        <a
                            href={siteInfo.social.whatsapp}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="WhatsApp"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="22"
                                height="22"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path
                                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.435 5.617 1.435h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                                ></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Map Card -->
            <div class="map-card fade-in-up delay-100">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15833.882101736932!2d-73.1207609!3d7.119349!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e683f0000000001%3A0x0!2sBucaramanga%2C%20Santander!5e0!3m2!1ses!2sco!4v1650000000000!5m2!1ses!2sco"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                >
                </iframe>
                <div class="map-overlay">
                    <span>Ver en Google Maps</span>
                </div>
            </div>
        </div>

        <!-- How We Work Section -->
        <section class="process-section fade-in-up delay-200">
            <div class="section-badge">Proceso Simple</div>
            <h2>La Experiencia Moncada</h2>

            <div class="process-steps">
                <div class="step-card">
                    <span class="step-number">01</span>
                    <h3>Inspírate</h3>
                    <p>
                        Navega nuestras colecciones diseñadas para resaltar tu
                        esencia única.
                    </p>
                </div>

                <div class="step-line"></div>

                <div class="step-card">
                    <span class="step-number">02</span>
                    <h3>Consulta</h3>
                    <p>
                        Escríbenos por WhatsApp. Un asesor experto resolverá tus
                        dudas al instante.
                    </p>
                </div>

                <div class="step-line"></div>

                <div class="step-card">
                    <span class="step-number">03</span>
                    <h3>Estrena</h3>
                    <p>
                        Recibe tu pedido en la puerta de tu casa, empaquetado
                        con el lujo que mereces.
                    </p>
                </div>
            </div>

            <div class="cta-wrapper text-center">
                <a
                    href={siteInfo.contact.whatsappUrl}
                    class="whatsapp-btn-premium"
                >
                    <span>Solicitar Asesoría Personalizada</span>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </a>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="faq-section fade-in-up delay-300">
            <div class="faq-header">
                <h2>Preguntas Frecuentes</h2>
                <p>Todo lo que necesitas saber antes de tu compra.</p>
            </div>

            <div class="faq-grid">
                {
                    siteInfo.faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">
                                {faq.question}
                                <span class="icon-plus" />
                            </summary>
                            <div class="faq-answer">
                                <p>{faq.answer}</p>
                            </div>
                        </details>
                    ))
                }
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    /* Animations */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0; /* Init hidden */
    }

    .delay-100 {
        animation-delay: 0.1s;
    }
    .delay-200 {
        animation-delay: 0.2s;
    }
    .delay-300 {
        animation-delay: 0.3s;
    }

    /* Hero Section */
    .contact-hero {
        position: relative;
        padding: 6rem 2rem 5rem;
        background: var(--color-bg-light);
        overflow: hidden;
    }

    .hero-bg-accent {
        position: absolute;
        top: 0;
        right: 0;
        width: 40%;
        height: 100%;
        background: radial-gradient(
            circle at top right,
            rgba(196, 164, 122, 0.1),
            transparent 70%
        );
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
        margin: 0 auto;
    }

    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--color-accent);
        font-weight: 600;
        margin-bottom: 1rem;
        display: block;
    }

    h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(3rem, 6vw, 4.5rem);
        color: var(--color-text-dark);
        margin: 0 0 1.5rem;
        font-weight: 700;
        line-height: 1.1;
        animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s;
    }

    .hero-description {
        font-size: 1.15rem;
        color: var(--color-text-light);
        max-width: 600px;
        margin: 0 auto;
        font-weight: 300;
        line-height: 1.8;
        animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s;
    }

    .hero-decoration-top,
    .hero-decoration-bottom {
        width: 60px;
        height: 1px;
        background: var(--color-accent);
        margin: 0 auto;
        opacity: 0.5;
    }
    .hero-decoration-top {
        margin-bottom: 2rem;
    }
    .hero-decoration-bottom {
        margin-top: 2rem;
    }

    /* Container */
    .contact-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
    }

    /* Grid Layout */
    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 2rem;
        margin-bottom: 8rem;
        margin-top: -3rem; /* Overlap hero slightly if desired, or just gap */
    }

    /* Info Card */
    .info-card {
        background: var(--color-card-bg);
        padding: 3rem;
        border-radius: 2px; /* Sharper corners for luxury feel */
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.03);
        border: 1px solid rgba(196, 164, 122, 0.2);
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .card-header {
        margin-bottom: 2.5rem;
    }

    .card-header h2 {
        font-family: "Playfair Display", serif;
        font-size: 1.75rem;
        color: var(--color-text-dark);
        margin-bottom: 0.5rem;
    }

    .info-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem;
        background: var(--color-bg-light);
        border: 1px solid transparent;
        transition: all 0.3s ease;
        text-decoration: none;
        position: relative;
    }

    a.info-item:hover {
        background: #fff;
        border-color: var(--color-accent);
        transform: translateX(5px);
        box-shadow: var(--shadow-sm);
    }

    .icon-box {
        color: var(--color-accent);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .info-text h3 {
        font-family: "Playfair Display", serif;
        font-size: 1rem;
        color: var(--color-text-dark);
        margin: 0 0 0.2rem;
    }

    .info-value {
        display: block;
        font-size: 1rem;
        color: var(--color-text-medium);
        font-weight: 500;
    }

    .info-sub {
        display: block;
        font-size: 0.8rem;
        color: var(--color-text-light);
        margin-top: 0.2rem;
        opacity: 0.8;
    }

    .arrow-icon {
        margin-left: auto;
        color: var(--color-accent);
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.3s ease;
    }

    a.info-item:hover .arrow-icon {
        opacity: 1;
        transform: translateX(0);
    }

    .social-connect {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .social-connect h3 {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-light);
        margin: 0;
    }

    .social-icons {
        display: flex;
        gap: 0.75rem;
    }

    .social-icons a {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-medium);
        background: var(--color-bg-light);
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .social-icons a:hover {
        background: var(--color-accent);
        color: white;
        transform: translateY(-2px);
    }

    /* Map Card */
    .map-card {
        position: relative;
        min-height: 100%;
        background: var(--color-bg-light);
        box-shadow: 20px 20px 0px rgba(196, 164, 122, 0.1); /* Decoration offset */
    }

    .map-card iframe {
        filter: grayscale(1) opacity(0.8);
        transition: all 0.5s ease;
    }

    .map-card:hover iframe {
        filter: grayscale(0) opacity(1);
    }

    .map-overlay {
        position: absolute;
        bottom: 2rem;
        left: 2rem;
        background: white;
        padding: 0.75rem 1.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        box-shadow: var(--shadow-md);
        pointer-events: none;
        opacity: 0.9;
    }

    /* Process Section */
    .process-section {
        margin-bottom: 8rem;
        text-align: center;
    }

    .section-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: var(--color-bg-dark);
        color: var(--color-text-dark);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 20px;
        margin-bottom: 1rem;
    }

    .process-section h2 {
        font-family: "Playfair Display", serif;
        font-size: 2.5rem;
        color: var(--color-text-dark);
        margin-bottom: 4rem;
    }

    .process-steps {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 4rem;
    }

    .step-card {
        flex: 1;
        max-width: 300px;
    }

    .step-number {
        font-family: "Playfair Display", serif;
        font-size: 4rem;
        color: var(--color-accent);
        line-height: 1;
        display: block;
        margin-bottom: 1rem;
    }

    .step-card h3 {
        font-size: 1.25rem;
        color: var(--color-text-dark);
        margin-bottom: 0.75rem;
        font-weight: 600;
    }

    .step-card p {
        font-size: 0.95rem;
        color: var(--color-text-light);
        line-height: 1.6;
    }

    .step-line {
        width: 100px;
        height: 1px;
        background: var(--color-border);
        margin-top: 2rem;
    }

    /* Premium Button */
    .whatsapp-btn-premium {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        background: var(--color-text-dark);
        color: #fff;
        padding: 1.25rem 3rem;
        font-family: "Playfair Display", serif;
        font-style: italic;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.4s ease;
        border: 1px solid var(--color-text-dark);
    }

    .whatsapp-btn-premium:hover {
        background: transparent;
        color: var(--color-text-dark);
    }

    /* FAQ Section */
    .faq-section {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .faq-header h2 {
        font-family: "Playfair Display", serif;
        font-size: 2.25rem;
        color: var(--color-text-dark);
        margin-bottom: 0.5rem;
    }

    .faq-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .faq-item {
        border-bottom: 1px solid var(--color-border);
    }

    .faq-question {
        padding: 1.5rem 0;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--color-text-dark);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        list-style: none; /* Hide default triangle */
        transition: color 0.3s ease;
    }

    .faq-question:hover {
        color: var(--color-accent);
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .icon-plus {
        position: relative;
        width: 16px;
        height: 16px;
    }

    .icon-plus::before,
    .icon-plus::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        background: currentColor;
        transform: translate(-50%, -50%);
        transition: transform 0.3s ease;
    }

    .icon-plus::before {
        width: 100%;
        height: 2px;
    }
    .icon-plus::after {
        width: 2px;
        height: 100%;
    }

    details[open] .icon-plus::after {
        transform: translate(-50%, -50%) rotate(90deg); /* Rotate to form minus if desired, or just opacity */
        opacity: 0;
    }

    .faq-answer {
        padding-bottom: 1.5rem;
        color: var(--color-text-light);
        line-height: 1.7;
        font-size: 0.95rem;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .contact-grid {
            grid-template-columns: 1fr;
            margin-top: 0;
        }

        .map-card {
            min-height: 400px;
            box-shadow: none;
        }

        .process-steps {
            flex-direction: column;
            align-items: center;
            gap: 3rem;
        }

        .step-line {
            display: none;
            width: 1px;
            height: 40px;
            margin: 0;
        }
    }

    @media (max-width: 600px) {
        .contact-hero {
            padding-top: 6rem;
        }

        h1 {
            font-size: 2.5rem;
        }

        .info-card {
            padding: 1.5rem;
        }

        .whatsapp-btn-premium {
            width: 100%;
            justify-content: center;
            padding: 1rem;
        }
    }
</style>
