---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products } from "../../data/products";
import ColorSelector from "../../components/ColorSelector.astro";
import { STRAPI_HOST } from "~/services/consts";
import { Image } from "astro:assets";
const { slug } = Astro.params;

// Encontrar el producto por slug
const product = products.find((p) => p.slug === slug);
console.log(product);

if (!product) {
    return Astro.redirect("/");
}

export const getStaticPaths = (() => {
    return products.map(({ slug }) => ({ params: { slug } }));
}) satisfies GetStaticPaths;
---

<BaseLayout title={`${product.name} - Tienda de Ropa`}>
    <div class="product-selection-page">
        <!-- Galería de imágenes -->
        <div class="gallery-section">
            <div class="main-image">
                {
                    product.images && product.images.length > 0 ? (
                        <Image
                            width={800}
                            height={800}
                            loading={"eager"}
                            src={`${STRAPI_HOST}${product.images[0].url}`}
                            alt={product.name}
                        />
                    ) : (
                        <div class="image-placeholder">📷</div>
                    )
                }
            </div>
            {
                product.images && product.images.length > 1 && (
                    <div class="thumbnail-gallery">
                        {product.images.map((img) => (
                            <button class="thumbnail" data-src={img.url}>
                                <Image
                                    width={100}
                                    height={100}
                                    loading={"lazy"}
                                    src={`${STRAPI_HOST}${img.url}`}
                                    alt="Thumbnail"
                                />
                            </button>
                        ))}
                    </div>
                )
            }
        </div>

        <!-- Sección de selección y recibo -->
        <div class="selection-section">
            <!-- Información del producto -->
            <div class="product-info">
                <h1>{product.name}</h1>
                <p class="description">{product.description}</p>
                <div class="price-section">
                    <span class="price">${product.price.toFixed(2)}</span>
                    <span class="availability">✓ En stock</span>
                </div>
            </div>

            <!-- Selecciones -->
            <div class="selections-container">
                <!-- Color Selector -->
                <div class="selection-group">
                    <ColorSelector
                        label="Elige tu color favorito"
                        activeColor="#FFE5D9"
                        colors={[
                            "#FFE5D9",
                            "#B4D7F1",
                            "#FFB6C1",
                            "#E8D5C4",
                            "#C4A47A",
                            "#8A7A72",
                        ]}
                    />
                </div>

                <!-- Tamaño Selector -->
                <div class="selection-group">
                    <label class="selector-label">Selecciona una talla</label>
                    <div class="sizes-grid">
                        {
                            product.size.map((size) => (
                                <button class="size-button" data-size={size}>
                                    {size}
                                </button>
                            ))
                        }
                    </div>
                </div>

                <!-- Cantidad -->
                <div class="selection-group">
                    <label class="selector-label">Cantidad</label>
                    <div class="quantity-selector">
                        <button class="qty-btn" id="decrease">−</button>
                        <input
                            type="number"
                            id="quantity"
                            value="1"
                            min="1"
                            max="10"
                        />
                        <button class="qty-btn" id="increase">+</button>
                    </div>
                </div>
            </div>

            <!-- Recibo / Resumen -->
            <div class="receipt-section">
                <h2>Resumen del Pedido</h2>
                <div class="receipt-item">
                    <span class="receipt-label">Producto:</span>
                    <span class="receipt-value">{product.name}</span>
                </div>
                <div class="receipt-item">
                    <span class="receipt-label">Precio unitario:</span>
                    <span class="receipt-value"
                        >${product.price.toFixed(2)}</span
                    >
                </div>
                <div class="receipt-item">
                    <span class="receipt-label">Color:</span>
                    <span class="receipt-value" id="selected-color"
                        >No seleccionado</span
                    >
                </div>
                <div class="receipt-item">
                    <span class="receipt-label">Talla:</span>
                    <span class="receipt-value" id="selected-size"
                        >No seleccionado</span
                    >
                </div>
                <div class="receipt-item">
                    <span class="receipt-label">Cantidad:</span>
                    <span class="receipt-value" id="selected-qty">1</span>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-item total">
                    <span class="receipt-label">Total:</span>
                    <span class="receipt-value" id="total-price"
                        >${product.price.toFixed(2)}</span
                    >
                </div>

                <!-- Botones de acción -->
                <div class="action-buttons">
                    <button class="btn-primary" id="add-to-cart"
                        >Añadir al Carrito</button
                    >
                    <button class="btn-secondary" id="continue-shopping"
                        >Seguir Comprando</button
                    >
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .product-selection-page {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
        animation: fadeInUp 0.6s ease-out;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Galería de imágenes */
    .gallery-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        sticky: top 2rem;
    }

    .main-image {
        width: 100%;
        aspect-ratio: 1;
        background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
        border-radius: 1.5rem;
        overflow: hidden;
        border: 2px solid rgba(232, 213, 196, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .main-image:hover img {
        transform: scale(1.05);
    }

    .image-placeholder {
        font-size: 4rem;
        opacity: 0.5;
    }

    .thumbnail-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
    }

    .thumbnail {
        aspect-ratio: 1;
        border: 2px solid rgba(232, 213, 196, 0.4);
        border-radius: 0.75rem;
        padding: 0;
        background: white;
        cursor: pointer;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .thumbnail:hover {
        border-color: #c4a47a;
        transform: translateY(-2px);
    }

    .thumbnail.active {
        border-color: #c4a47a;
        box-shadow: 0 0 0 2px rgba(196, 164, 122, 0.2);
    }

    /* Sección de selección */
    .selection-section {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .product-info h1 {
        font-size: 2.2rem;
        margin: 0 0 1rem 0;
        font-weight: 700;
        color: #5a4a42;
        letter-spacing: -0.02em;
    }

    .description {
        color: #8a7a72;
        font-size: 1rem;
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
    }

    .price-section {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
        border-radius: 1rem;
        border: 1px solid rgba(232, 213, 196, 0.4);
    }

    .price {
        font-size: 2rem;
        font-weight: 700;
        color: #a89080;
    }

    .availability {
        color: #6ba876;
        font-weight: 600;
        font-size: 0.95rem;
    }

    /* Selecciones */
    .selections-container {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding: 2rem;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.7) 0%,
            rgba(245, 241, 232, 0.7) 100%
        );
        border: 2px solid rgba(232, 213, 196, 0.4);
        border-radius: 1.5rem;
    }

    .selection-group {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .selector-label {
        font-size: 1rem;
        font-weight: 600;
        color: #5a4a42;
        letter-spacing: 0.05em;
    }

    .sizes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(70px, 1fr));
        gap: 0.8rem;
    }

    .size-button {
        padding: 0.8rem;
        border: 2px solid #e8d5c4;
        background: white;
        color: #5a4a42;
        border-radius: 0.75rem;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: "Poppins", sans-serif;
    }

    .size-button:hover {
        border-color: #c4a47a;
        background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
        transform: translateY(-2px);
    }

    .size-button.active {
        background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
        color: white;
        border-color: #a89080;
    }

    .quantity-selector {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: white;
        border: 2px solid #e8d5c4;
        border-radius: 0.75rem;
        padding: 0.5rem;
        width: fit-content;
    }

    .qty-btn {
        width: 2.5rem;
        height: 2.5rem;
        border: none;
        background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
        color: #5a4a42;
        border-radius: 0.5rem;
        font-size: 1.2rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .qty-btn:hover {
        background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
        color: white;
        transform: scale(1.05);
    }

    #quantity {
        width: 3rem;
        text-align: center;
        border: none;
        background: transparent;
        font-size: 1.1rem;
        font-weight: 600;
        color: #5a4a42;
        font-family: "Poppins", sans-serif;
    }

    #quantity:focus {
        outline: none;
    }

    /* Recibo */
    .receipt-section {
        padding: 2rem;
        background: linear-gradient(135deg, #fafaf8 0%, #f5f1e8 100%);
        border: 2px solid rgba(232, 213, 196, 0.6);
        border-radius: 1.5rem;
        box-shadow: 0 4px 15px rgba(172, 140, 124, 0.1);
    }

    .receipt-section h2 {
        margin: 0 0 1.5rem 0;
        font-size: 1.3rem;
        color: #5a4a42;
        font-weight: 700;
    }

    .receipt-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 0;
        font-size: 0.95rem;
    }

    .receipt-label {
        color: #8a7a72;
        font-weight: 500;
    }

    .receipt-value {
        color: #5a4a42;
        font-weight: 600;
        max-width: 50%;
        text-align: right;
    }

    .receipt-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #e8d5c4, transparent);
        margin: 1rem 0;
    }

    .receipt-item.total {
        background: linear-gradient(
            135deg,
            rgba(168, 144, 128, 0.1) 0%,
            rgba(196, 164, 122, 0.1) 100%
        );
        padding: 1rem;
        border-radius: 0.75rem;
        margin-top: 0.5rem;
    }

    .receipt-item.total .receipt-label {
        color: #5a4a42;
        font-weight: 700;
        font-size: 1.05rem;
    }

    .receipt-item.total .receipt-value {
        color: #a89080;
        font-size: 1.5rem;
        font-weight: 700;
    }

    /* Botones de acción */
    .action-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-primary,
    .btn-secondary {
        padding: 1rem;
        border: none;
        border-radius: 0.75rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: "Poppins", sans-serif;
    }

    .btn-primary {
        background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(172, 140, 124, 0.2);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(172, 140, 124, 0.3);
    }

    .btn-secondary {
        background: white;
        color: #a89080;
        border: 2px solid #e8d5c4;
    }

    .btn-secondary:hover {
        border-color: #c4a47a;
        background: linear-gradient(135deg, #f5f1e8 0%, #ede8e0 100%);
        transform: translateY(-2px);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .product-selection-page {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .gallery-section {
            sticky: unset;
        }
    }

    @media (max-width: 768px) {
        .product-info h1 {
            font-size: 1.8rem;
        }

        .sizes-grid {
            grid-template-columns: repeat(auto-fit, minmax(60px, 1fr));
        }

        .action-buttons {
            grid-template-columns: 1fr;
        }

        .thumbnail-gallery {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 640px) {
        .selections-container {
            padding: 1.5rem;
        }

        .receipt-section {
            padding: 1.5rem;
        }

        .price-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .product-info h1 {
            font-size: 1.5rem;
        }

        .sizes-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .thumbnail-gallery {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<script>
    // Selector de talla
    document.querySelectorAll(".size-button").forEach((btn) => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".size-button").forEach((b) => {
                b.classList.remove("active");
            });
            btn.classList.add("active");
            const selectedSize = btn.getAttribute("data-size");
            const receiptSize = document.getElementById("selected-size");
            if (receiptSize) {
                receiptSize.textContent = selectedSize;
            }
            updateTotal();
        });
    });

    // Selector de color
    document.addEventListener("colorChange", (e: any) => {
        const receiptColor = document.getElementById("selected-color");
        if (receiptColor) {
            const colorLabels: Record<string, string> = {
                "#FFE5D9": "Coral Claro",
                "#B4D7F1": "Azul Cielo",
                "#FFB6C1": "Rosa Suave",
                "#E8D5C4": "Beige Cálido",
                "#C4A47a": "Marrón Tostado",
                "#8A7A72": "Gris Taupe",
            };
            receiptColor.textContent =
                colorLabels[e.detail.color] || e.detail.color;
        }
    });

    // Cantidad
    const quantityInput = document.getElementById(
        "quantity",
    ) as HTMLInputElement;
    const decreaseBtn = document.getElementById("decrease");
    const increaseBtn = document.getElementById("increase");

    function updateTotal() {
        const pricePerUnit = parseFloat(
            document.querySelector(".price")?.textContent?.replace("$", "") ||
                "0",
        );
        const quantity = parseInt(quantityInput.value) || 1;
        const total = (pricePerUnit * quantity).toFixed(2);

        const totalPrice = document.getElementById("total-price");
        const selectedQty = document.getElementById("selected-qty");

        if (totalPrice) totalPrice.textContent = `$${total}`;
        if (selectedQty) selectedQty.textContent = quantity.toString();
    }

    decreaseBtn?.addEventListener("click", () => {
        let value = parseInt(quantityInput.value) || 1;
        if (value > 1) {
            quantityInput.value = (value - 1).toString();
            updateTotal();
        }
    });

    increaseBtn?.addEventListener("click", () => {
        let value = parseInt(quantityInput.value) || 1;
        if (value < 10) {
            quantityInput.value = (value + 1).toString();
            updateTotal();
        }
    });

    quantityInput?.addEventListener("change", updateTotal);

    // Galería de imágenes
    document.querySelectorAll(".thumbnail").forEach((thumb) => {
        thumb.addEventListener("click", () => {
            const src = thumb.getAttribute("data-src");
            const mainImg = document.querySelector(
                ".main-image img",
            ) as HTMLImageElement;
            if (mainImg && src) {
                mainImg.src = src;
                document.querySelectorAll(".thumbnail").forEach((t) => {
                    t.classList.remove("active");
                });
                thumb.classList.add("active");
            }
        });
    });

    // Botones de acción
    document.getElementById("add-to-cart")?.addEventListener("click", () => {
        alert("Producto añadido al carrito!");
    });

    document
        .getElementById("continue-shopping")
        ?.addEventListener("click", () => {
            window.history.back();
        });
</script>
