---
const { title = "Astro Ecommerce" } = Astro.props;
import { ClientRouter } from "astro:transitions";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="header">
      <div class="container">
        <div class="header-content">
          <div class="header-top">
            <div class="logo-section">
              <div class="logo-icon">✨</div>
              <h1>BLUSAS</h1>
            </div>
            <nav class="nav">
              <a href="/" class="nav-link">Inicio</a>
              <a href="/categories" class="nav-link">Categorías</a>
            </nav>
          </div>
          <p class="subtitle">Ropa cómoda y elegante para ti</p>
        </div>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          💝 © {new Date().getFullYear()} Tienda de Blusas • Hecho con amor ✨
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    font-family:
      "Poppins",
      system-ui,
      -apple-system,
      sans-serif;
    background: linear-gradient(135deg, #faf9f7 0%, #f5f1e8 50%, #ede8e0 100%);
    color: #5a4a42;
  }

  .header {
    background: linear-gradient(135deg, #ffffff 0%, #fdf8f3 100%);
    padding: 2rem 0;
    border-bottom: 2px solid #e8d5c4;
    box-shadow: 0 2px 8px rgba(172, 140, 124, 0.1);
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: #a89080;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover {
    color: #c4a47a;
    border-bottom-color: #c4a47a;
  }

  .logo-section {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .logo-icon {
    font-size: 2rem;
  }

  .header h1 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    background: linear-gradient(135deg, #a89080 0%, #c4a47a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.15em;
  }

  .subtitle {
    margin: 0;
    font-size: 0.95rem;
    color: #a89080;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .container {
    width: min(1200px, 100% - 2rem);
    margin-inline: auto;
  }

  main.container {
    padding: 3rem 0;
  }

  .footer {
    border-top: 2px solid #e8d5c4;
    padding: 2rem 0;
    font-size: 0.9rem;
    color: #a89080;
    text-align: center;
    background: linear-gradient(135deg, #fafaf8 0%, #f5f1e8 100%);
    margin-top: 3rem;
    font-weight: 300;
  }

  @media (max-width: 640px) {
    .header-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .nav {
      width: 100%;
      justify-content: flex-start;
      gap: 1.5rem;
    }

    .nav-link {
      font-size: 0.9rem;
    }
  }
</style>
