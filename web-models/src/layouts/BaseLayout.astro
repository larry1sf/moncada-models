---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { categories } from "../data/categories";
import ModalCart from "~/components/ModalCart.astro";
import { STRAPI_HOST } from "~/services/consts";
interface Props {
    title: string;
}
import { products } from "~/data/products";
import { siteInfo } from "~/data/siteInfo";
const { title } = Astro.props;
---

<script>
    interface CartItem {
        id: string;
        name: string;
        price: number;
        quantity: number;
    }

    // Función para actualizar el contador del carrito
    const updateCartCounter = () => {
        const quantityDisplay = document.querySelector("#cart-quantity");
        if (!quantityDisplay) return;

        try {
            const cart = JSON.parse(
                window.localStorage.getItem("cart") || "[]",
            ) as CartItem[];
            const totalQuantity = cart.reduce(
                (acc, item) => acc + item?.quantity,
                0,
            );
            quantityDisplay.textContent = totalQuantity.toString();
        } catch (e) {
            console.error("Error updating cart counter:", e);
            quantityDisplay.textContent = "0";
        }
    };

    // Función para cerrar el modal
    const handleClose = () => {
        const cartModal = document.querySelector(".modal-overlay");
        const modalContent = cartModal?.children[0];
        modalContent?.classList.remove("active");
        modalContent?.classList.add("close");

        setTimeout(() => {
            cartModal?.classList.remove("active");
            modalContent?.classList.remove("close");
        }, 300);
    };

    // Función para configurar el botón del carrito
    function setupCartButton() {
        const cartBtn = document.querySelector("#cart-btn");
        const cartModal = document.querySelector(".modal-overlay");
        const modalContent = cartModal?.children[0];

        if (!cartBtn) return;

        // Asegurar que el modal esté cerrado al configurar
        if (cartModal?.classList.contains("active")) {
            handleClose();
        }

        // Limpiar listeners anteriores clonando el botón
        const newCartBtn = cartBtn.cloneNode(true);
        cartBtn.parentNode?.replaceChild(newCartBtn, cartBtn);

        // Agregar nuevo listener
        newCartBtn.addEventListener("click", () => {
            const isActive = cartModal?.classList.contains("active");
            if (!isActive) {
                // Abrir modal usando el evento personalizado
                document.dispatchEvent(new Event("openCartModal"));
            } else {
                handleClose();
            }
        });
    }

    // Función de inicialización completa
    const initCartUI = () => {
        updateCartCounter();
        setupCartButton();
    };

    // Inicializar cuando el DOM esté listo
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCartUI);
    } else initCartUI();

    // Reinicializar después de navegaciones de Astro
    document.addEventListener("astro:page-load", initCartUI);

    // Actualizar contador cuando cambie el carrito
    window.addEventListener("cartUpdated", updateCartCounter);
</script>

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
    </head>
    <body>
        <ModalCart />

        <header
            data-strapi-host={STRAPI_HOST}
            data-products={JSON.stringify(products)}
            data-products-results="[]"
            class="main-header"
        >
            <div class="header-container">
                <a href="/" class="logo">
                    <span class="logo-icon">M</span>
                    <span class="logo-text">
                        <span class="logo-main">Moncada</span>
                        <span class="logo-sub">Models</span>
                    </span>
                </a>

                <nav class="main-nav">
                    <a href="/" class="nav-link">Inicio</a>
                    <a href="/#novedades" class="nav-link">Novedades</a>

                    <div class="nav-dropdown">
                        <a
                            href={Astro.originPathname === "/"
                                ? "/#colecciones"
                                : "/categories"}
                            class="nav-link dropdown-trigger"
                        >
                            Colecciones
                            <svg
                                class="dropdown-icon"
                                width="12"
                                height="12"
                                viewBox="0 0 12 12"
                                fill="none"
                            >
                                <path
                                    d="M3 4.5L6 7.5L9 4.5"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                        </a>
                        <div class="dropdown-menu">
                            <div class="dropdown-content">
                                {
                                    categories.map((category) => (
                                        <a
                                            href={`/category/${category.slug}`}
                                            class="dropdown-item"
                                        >
                                            <span class="dropdown-item-title">
                                                {category.title}
                                            </span>
                                            <span class="dropdown-item-count">
                                                {category.productCount}{" "}
                                                productos
                                            </span>
                                        </a>
                                    ))
                                }
                                <a
                                    href="/categories"
                                    class="dropdown-item view-all"
                                >
                                    <span class="dropdown-item-title"
                                        >Todas las Colecciones</span
                                    >
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 16 16"
                                        fill="none"
                                    >
                                        <path
                                            d="M6 12L10 8L6 4"
                                            stroke="currentColor"
                                            stroke-width="1.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"></path>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    <a href="/#newsletter" class="nav-link">Contacto</a>
                </nav>

                <div class="header-actions">
                    <div class="search-container">
                        <input
                            type="text"
                            class="search-input"
                            placeholder="Buscar..."
                            aria-label="Buscar productos"
                        />
                        <button
                            class="icon-btn search-trigger"
                            aria-label="Buscar"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <circle cx="11" cy="11" r="8"></circle>
                                <path d="m21 21-4.35-4.35"></path>
                            </svg>
                        </button>
                        <div class="search-results-dropdown"></div>
                    </div>
                    <button
                        id="cart-btn"
                        class="icon-btn cart-btn"
                        aria-label="Carrito"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="8" cy="21" r="1"></circle>
                            <circle cx="19" cy="21" r="1"></circle>
                            <path
                                d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"
                            ></path>
                        </svg>
                        <span id="cart-quantity" class="cart-badge">0</span>
                    </button>
                </div>

                <button class="mobile-menu-btn" aria-label="Menú">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
            <div class="search-overlay"></div>
        </header>
        <div class="mobile-nav-overlay"></div>
        <nav class="mobile-nav">
            <div class="mobile-nav-header">
                <span class="mobile-nav-title">Menú</span>
                <button class="mobile-nav-close" aria-label="Cerrar menú">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M18 6 6 18"></path><path d="m6 6 18 12"
                        ></path></svg
                    >
                </button>
            </div>
            <div class="mobile-nav-content">
                <a href="/" class="mobile-nav-link">Inicio</a>
                <a href="/#novedades" class="mobile-nav-link">Novedades</a>

                <div class="mobile-nav-group">
                    <button class="mobile-nav-link group-trigger">
                        Colecciones
                        <svg
                            class="group-icon"
                            width="16"
                            height="16"
                            viewBox="0 0 12 12"
                            fill="none"
                        >
                            <path
                                d="M3 4.5L6 7.5L9 4.5"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                    </button>
                    <div class="mobile-nav-submenu">
                        {
                            categories.map((category) => (
                                <a
                                    href={`/category/${category.slug}`}
                                    class="mobile-submenu-item"
                                >
                                    {category.title}
                                </a>
                            ))
                        }
                        <a
                            href="/categories"
                            class="mobile-submenu-item view-all"
                        >
                            Ver todas
                        </a>
                    </div>
                </div>

                <a href="/#newsletter" class="mobile-nav-link">Contacto</a>
            </div>
        </nav>

        <script>
            document.addEventListener("astro:page-load", () => {
                const mobileBtn = document.querySelector(".mobile-menu-btn");
                const mobileNav = document.querySelector(".mobile-nav");
                const overlay = document.querySelector(".mobile-nav-overlay");
                const closeBtn = document.querySelector(".mobile-nav-close");
                const groupTrigger = document.querySelector(".group-trigger");
                const submenu = document.querySelector(".mobile-nav-submenu");
                const groupIcon = document.querySelector(".group-icon");
                const mainHeader = document.querySelector(
                    ".main-header",
                ) as HTMLElement;

                if (!mainHeader) return;

                const productsData = mainHeader.dataset.products;
                const strapiHostData = mainHeader.dataset.strapiHost;

                const products = productsData ? JSON.parse(productsData) : [];
                const strapiHost = strapiHostData || "";

                function toggleMenu() {
                    mobileNav?.classList.toggle("active");
                    overlay?.classList.toggle("active");
                    document.body.style.overflow =
                        mobileNav?.classList.contains("active") ? "hidden" : "";
                }

                mobileBtn?.addEventListener("click", toggleMenu);
                closeBtn?.addEventListener("click", toggleMenu);
                overlay?.addEventListener("click", toggleMenu);

                // Submenu toggle
                groupTrigger?.addEventListener("click", () => {
                    submenu?.classList.toggle("active");
                    groupIcon?.classList.toggle("rotate");
                });

                // Close menu when clicking a link
                const mobileLinks = document.querySelectorAll(
                    ".mobile-nav-link:not(.group-trigger), .mobile-submenu-item",
                );
                mobileLinks.forEach((link) => {
                    link.addEventListener("click", toggleMenu);
                });

                // Search functionality
                const searchContainer =
                    document.querySelector(".search-container");
                const searchTrigger = document.querySelector(".search-trigger");
                const searchInput = document.querySelector(
                    ".search-input",
                ) as HTMLInputElement | null;
                const searchOverlay = document.querySelector(".search-overlay");
                const searchResultsDropdown = document.querySelector(
                    ".search-results-dropdown",
                ) as HTMLElement;

                if (
                    searchTrigger &&
                    searchInput &&
                    searchContainer &&
                    searchOverlay &&
                    searchResultsDropdown
                ) {
                    const closeSearch = () => {
                        searchContainer.classList.remove("active");
                        searchOverlay.classList.remove("active");
                        searchResultsDropdown.classList.remove("active");
                        // Reset height styles in case they were stuck during an animation
                        searchResultsDropdown.style.height = "";
                        searchResultsDropdown.style.transition = "";
                        document.body.style.overflow = "";
                    };

                    const openSearch = () => {
                        searchContainer.classList.add("active");
                        searchOverlay.classList.add("active");
                        searchInput.focus();
                        document.body.style.overflow = "hidden"; // Prevent scrolling
                        // Trigger search if there's already text
                        if (searchInput.value.trim() !== "") {
                            search();
                        }
                    };

                    interface SearchProduct {
                        slug: string;
                        name: string;
                        price: number;
                        images: { url: string }[];
                    }

                    let resultTransitionHandler: (() => void) | null = null;

                    const renderResults = (results: SearchProduct[]) => {
                        // Clear any pending transition cleanup to prevents race conditions
                        if (resultTransitionHandler) {
                            searchResultsDropdown.removeEventListener(
                                "transitionend",
                                resultTransitionHandler,
                            );
                            resultTransitionHandler = null;
                        }

                        searchResultsDropdown.innerHTML = "";
                        if (results.length === 0) {
                            if (searchInput.value.trim() !== "") {
                                searchResultsDropdown.innerHTML = `
                                <div class="no-results">
                                    No se encontraron productos
                                </div>
                            `;
                                searchResultsDropdown.classList.add("active");
                            } else {
                                searchResultsDropdown.classList.remove(
                                    "active",
                                );
                            }
                            return;
                        }

                        const html = results
                            .map(
                                (product) => `
                        <a href="/product/${product.slug}" class="search-result-item">
                            <div class="search-result-image-wrapper">
                                <img src="${strapiHost}${product.images[0]?.url || "/placeholder.jpg"}" alt="${product.name}" class="search-result-thumb" />
                            </div>
                            <div class="search-result-info">
                                <span class="search-result-category">${"Producto"}</span>
                                <span class="search-result-title">${product.name}</span>
                                <span class="search-result-price">$${product.price.toLocaleString()}</span>
                            </div>
                            <div class="search-result-action">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </div>
                        </a>
                    `,
                            )
                            .join("");

                        // Animation logic:
                        // 1. Get current height/state
                        const wasActive =
                            searchResultsDropdown.classList.contains("active");
                        const startHeight = searchResultsDropdown.offsetHeight;

                        // 2. Lock height if active to prevent jump when content changes
                        if (wasActive) {
                            searchResultsDropdown.style.height = `${startHeight}px`;
                        }

                        searchResultsDropdown.innerHTML = html;
                        searchResultsDropdown.classList.add("active");

                        if (wasActive) {
                            // 3. Measure new height
                            const MAX_HEIGHT = 450;
                            const newHeight = Math.min(
                                searchResultsDropdown.scrollHeight,
                                MAX_HEIGHT,
                            );

                            // Only animate if the difference is significant (e.g., more than ~40px)
                            // This prevents "jittery" animations for small content changes
                            if (Math.abs(startHeight - newHeight) > 40) {
                                // 4. Animate
                                // Force reflow to ensure the locked height is applied
                                searchResultsDropdown.offsetHeight;

                                // Smoother ease-out curve and slightly longer duration
                                searchResultsDropdown.style.transition =
                                    "height 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.3s ease, visibility 0.3s ease, transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)";
                                searchResultsDropdown.style.height = `${newHeight}px`;

                                // 5. Cleanup
                                resultTransitionHandler = () => {
                                    searchResultsDropdown.style.height = "auto";
                                    searchResultsDropdown.style.transition = "";
                                    if (resultTransitionHandler) {
                                        searchResultsDropdown.removeEventListener(
                                            "transitionend",
                                            resultTransitionHandler,
                                        );
                                        resultTransitionHandler = null;
                                    }
                                };
                                searchResultsDropdown.addEventListener(
                                    "transitionend",
                                    resultTransitionHandler,
                                );
                            } else {
                                // Height didn't change significantly, just unlock
                                searchResultsDropdown.style.height = "auto";
                            }
                        }
                    };

                    const search = () => {
                        const query = searchInput.value.toLowerCase().trim();
                        if (query === "") {
                            searchResultsDropdown.classList.remove("active");
                            return;
                        }

                        const result = products.filter(
                            (product: SearchProduct) =>
                                product.name.toLowerCase().includes(query),
                        );

                        // Update dataset for potential other uses
                        if (mainHeader) {
                            mainHeader.dataset.productsResults =
                                JSON.stringify(result);
                        }

                        renderResults(result);
                    };

                    searchTrigger.addEventListener("click", (e) => {
                        if (
                            searchContainer.classList.contains("active") &&
                            searchInput.value.trim() !== ""
                        ) {
                            // If active and has value, maybe just focus input or ensure results are shown
                            searchInput.focus();
                            search();
                        } else {
                            e.preventDefault();
                            if (searchContainer.classList.contains("active")) {
                                closeSearch();
                            } else {
                                openSearch();
                            }
                        }
                    });

                    // Simple debounce function
                    const debounce = (func: Function, wait: number) => {
                        let timeout: any;
                        return (...args: any[]) => {
                            clearTimeout(timeout);
                            timeout = setTimeout(
                                () => func.apply(this, args),
                                wait,
                            );
                        };
                    };

                    // Handle input typing with debounce (300ms)
                    const debouncedSearch = debounce(search, 300);
                    searchInput.addEventListener("input", debouncedSearch);

                    // Handle input focus
                    searchInput.addEventListener("focus", () => {
                        if (searchInput.value.trim() !== "") {
                            search();
                        }
                    });

                    // Handle Enter key
                    searchInput.addEventListener("keypress", (e) => {
                        if (e.key === "Enter") {
                            search();
                        }
                    });

                    // Close search when clicking outside
                    searchOverlay.addEventListener("click", closeSearch);

                    document.addEventListener("click", (e) => {
                        const target = e.target as Node;
                        // Don't close if clicking inside search container or dropdown
                        if (
                            !searchContainer.contains(target) &&
                            !searchOverlay.contains(target) &&
                            searchContainer.classList.contains("active")
                        ) {
                            closeSearch();
                        }
                    });

                    // Handle Escape key
                    document.addEventListener("keydown", (e) => {
                        if (
                            e.key === "Escape" &&
                            searchContainer.classList.contains("active")
                        ) {
                            closeSearch();
                        }
                    });
                }
            });
        </script>

        <main class="max-w">
            <slot />
        </main>

