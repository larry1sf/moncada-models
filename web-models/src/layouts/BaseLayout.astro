</html>

<style>
    /* Global Styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: "Poppins", sans-serif;
        background: #f5f1e8;
        color: #2c2420;
        line-height: 1.6;
        overflow-x: hidden;
    }
    .max-w {
        max-width: 1300px;
        padding: 2rem;
        margin-inline: auto;
    }
    /* Header Styles */
    .main-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(196, 164, 122, 0.15);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    }

    .header-container {
        position: relative; /* Anchor for absolute positioning of search input */
        max-width: 1400px;
        margin: 0 auto;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
    }

    /* Professional Logo Design */
    .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .logo-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, #c4a47a 0%, #a89080 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Playfair Display", serif;
        font-size: 1.5rem;
        font-weight: 700;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(196, 164, 122, 0.25);
        transition: all 0.3s ease;
    }

    .logo:hover .logo-icon {
        transform: translateY(-2px);
